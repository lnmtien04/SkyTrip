id":0,"custom_tags":null,"tag_ids":null},{"id":49298,"instance":2,"participate":99480,"url_seo":"","video_url":"https://res.klook.com/video/upload/fl_lossy.progressive,q_85,f_auto/c_fill,,/c_scale,h_540,vc_auto/c_scale,g_north_west,h_20,l_whitelogo_hz5dq1,o_30,x_70,y_480/c_scale,f_mp4,fl_splice,h_540,l_video:ending_trgtvv/v1676976046/activities/rlcd0okiubjq4exykv1m.mp4","score":4.6,"published":true,"review_total":5472,"title":"Vé Xe Inter Bus Lines Hà Nội - Sapa và ngược lại","date_de\u0073\u0063\u0072\u0069\u0070\u0074ion":"","template_id":5,"sub_category":0,"leaf_category":582,"country_id":13,"country_code":"","city_id":34,"city_name":"","latlng":"21.027765,105.83416","latlng_wgs84":"","first_publish_time":"2020-09-23T15:36:21.000Z","display_package_card":0,"image_url":"","country_name":"","activity_type":"","image_url_host":"https://res.klook.com/image/upload/activities/zyeq6vtnh52q0ho4k86j.jpg","published_language":["fi_FI","en_MY","en_IN","ms_MY","en_AU","en_HK","vi_VN","id_ID","ru_RU","fr_FR","zh_HK","en_SG","en_NZ","en_AE","it_IT","ko_KR","cs_CZ","ja_JP","el_GR","es_ES","en_BS","en_GB","en_US","de_DE","en_CA","th_TH","en_PH","zh_CN","zh_TW"],"real_lang":"","language_publish_status":0,"language_once_published":false,"viewable_platform":0,"publish_info":{"publish_status":0,"publish_status_desc":"","published_time_utc":""},"currency":"VND","package_id":0,"market_price":"290000","sell_price":"250000","from_price":"250000","to_price":"437500","spec_price":{"type":0,"desc":""},"start_time":"2026-04-21 07:30:00","sold_out":false,"package_count":0,"hot_state":"","participants_format":"90K+ Đã đặt","discount":0,"card_tags":{"10th_birthday_sales":"Ưu đãi xuân"},"tags":[{"key":"10th_birthday_sales","background_color_left":"#FF5722","background_color_right":"#FF5722","text_color":"#FFFFFF","text":"Ưu đãi xuân"}],"icon":null,"icons":[],"min_trip":0,"ysim_info":{},"is_srv_activity":false,"is_nsw_activity":false,"detail_hotel":null,"NeedHideReview":false,"DeepLink":"activity/49298-interbus-lines-bus-ticket-hanoi-sapa/","need_hide_review":false,"deeplink":"","deep_link":"/vi/activity/49298-interbus-lines-bus-ticket-hanoi-sapa/","vertical_type":0,"vertical_id":0,"custom_tags":null,"tag_ids":null}]},{"priority":0,"display_status":0,"card_url":"https://res.klook.com/image/upload/cities/rxqumcihtzatvhcnbedi.jpg","name":"Đà Nẵng","id":74,"dest_id":0,"de\u0073\u0063\u0072\u0069\u0070\u0074ion":"Đà Nẵng, một đô thị ven biển năng động ở miền Trung Việt Nam, đã trở thành một viên ngọc quý theo đúng nghĩa của nó, tự hào với những bãi biển hoang sơ, những ngọn đồi xanh tươi và một bầu không khí hiện đại nhưng vẫn thư thái. Đường chân trời của thành phố được tô điểm bởi những địa danh biểu tượng như Cầu Vàng hùng vĩ trên Bà Nà Hills và Cầu Rồng ngoạn mục, nơi phun lửa vào một số buổi tối. Ngoài ra, du khách có thể khám phá Ngũ Hành Sơn huyền bí, một cụm năm đỉnh núi đá vôi với nhiều hang động và đền thờ Phật giáo, hoặc thư giãn trên bãi biển Mỹ Khê nổi tiếng với bãi cát mịn và làn nước trong vắt. Những người yêu thích hoạt động ngoài trời có thể khám phá bán đảo Sơn Trà, nơi cây xanh tươi tốt và tượng Phật Bà Quan Âm cao chót vót đang chờ đón, trong khi những tín đồ mua sắm và ẩm thực sẽ thích thú dạo quanh Chợ Hàn nhộn nhịp và thưởng thức những món ăn địa phương yêu thích bên bờ sông. Chuyến đi đến Đà Nẵng sẽ không trọn vẹn nếu thiếu chuyến viếng thăm Thánh địa Mỹ Sơn, một trong những Di sản Thế giới được UNESCO công nhận của Việt Nam. Với vô số di tích đền thờ lịch sử và các tác phẩm điêu khắc đá, đây thực sự là một cảnh tượng đáng chiêm ngưỡng! Với sự pha trộn giữa vẻ đẹp thiên nhiên, nét văn hóa đặc sắc và nét quyến rũ hiện đại, Đà Nẵng mời gọi du khách khám phá những điểm đến đa dạng.","location":"16.054407,108.202167","seo_url":"da-nang","keywords":[{"keyword":"Khu di tích thế giới","image":""},{"keyword":"Kiến trúc ấn tượng","image":""},{"keyword":"Kỳ quan thiên nhiên","image":""}],"hot_activities":[{"id":13283,"instance":1,"participate":15