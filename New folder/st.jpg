DeepLink":"activity/23321-han-river-cruise-my-xuan-cruise-da-nang/","need_hide_review":false,"deeplink":"","deep_link":"/vi/activity/23321-han-river-cruise-my-xuan-cruise-da-nang/","vertical_type":0,"vertical_id":0,"custom_tags":null,"tag_ids":null}]},{"priority":0,"display_status":0,"card_url":"https://res.klook.com/image/upload/v1760521763/destination/wncqdlsfudyzz1etgoqc.jpg","name":"Hạ Long","id":486,"dest_id":0,"de\u0073\u0063\u0072\u0069\u0070\u0074ion":"Hạ Long, thành phố biển thuộc tỉnh Quảng Ninh, nổi tiếng với Vịnh Hạ Long - di sản thiên nhiên thế giới được UNESCO công nhận. Vịnh sở hữu hơn 1.600 đảo đá vôi lớn nhỏ, làn nước xanh ngọc bích và những hang động kỳ ảo như Hang Sửng Sốt, Động Thiên Cung. Chỉ cách Hà Nội khoảng 170 km, du khách có thể trải nghiệm du thuyền sang trọng, chèo thuyền kayak, tắm biển tại Bãi Cháy hay ngắm nhìn toàn cảnh vịnh từ núi Bài Thơ. Thành phố còn có Công viên Sun World Hạ Long với nhiều trò chơi giải trí hấp dẫn dành cho cả gia đình. Ẩm thực phong phú với hải sản tươi sống cũng là một điểm nhấn khiến Hạ Long trở thành điểm đến không thể bỏ qua.","location":"20.971198,107.044807","seo_url":"halong","keywords":[{"keyword":"Khu di tích thế giới","image":""},{"keyword":"Kỳ quan thiên nhiên","image":""},{"keyword":"Điểm đến không thể bỏ qua","image":""}],"hot_activities":[{"id":55771,"instance":1,"participate":34956,"url_seo":"","video_url":"https://res.klook.com/video/upload/fl_lossy.progressive,q_85,f_auto/c_fill,,/c_scale,h_540,vc_auto/c_scale,g_north_west,h_20,l_whitelogo_hz5dq1,o_30,x_70,y_480/v1765782895/activities/h83tmko5xpwiavwf7heg.mp4","score":4.8,"published":true,"review_total":3551,"title":"Tour Ngày Du Thuyền Diamond Era: Vịnh Hạ Long, Hang Sửng Sốt, Ti Top","date_de\u0073\u0063\u0072\u0069\u0070\u0074ion":"","template_id":2,"sub_category":0,"leaf_category":156,"country_id":13,"country_code":"","city_id":486,"city_name":"","latlng":"20.971198,107.044807","latlng_wgs84":"","first_publish_time":"2021-03-29T17:31:38.000