                <h1 class="search_landing_keywoed common_container" id="best_thing_to_do">Việt Nam có gì đặc biệt?</h1>
                <div class="search_page common_container" id='searchRef'>
                    <div class="search_left">
                        <div class="search_left_select">
                            <div class="select_tag search_left_template" v-show="selectTagList && selectTagList.length">
                                <div class="type_title">
                                    ĐÃ CHỌN
                                </div>
                                <div class="tag_list">
                                    <div v-for="item in selectTagList">
                                        <div :type-id="item.id" class="tag_name" @click="clearTagFn(item)">
                                            <span>${item.name}</span>
                                            <klk-symbol href="close-c" class="close-c"></klk-symbol>
                                        </div>
                                    </div>
                                </div>
                                <div class="clear_all_tag" v-show="selectTagList && selectTagList.length > 1">
                                    <span class="clear_tag" @click="clearAllSelectTag">Xóa chọn</span>
                                </div>
                            </div>
                            <div v-if="nswFilter.nsw_act_content" class="search_left_template">
                                <div class="type_title">
                                    Parents NSW Vouchers
                                </div>
                                <div class="u_checkbox_square">
                                    <input
                                            :class="['checkTree']"
                                            :value="nswFilter.isChecked"
                                            type="checkbox"
                                            @change="updateNswFilter"
                                            :checked="nswFilter.isChecked"
                                    >
                                    <label>
                                        <span>${ nswFilter.nsw_act_content }</span>
                                    </label>
                                </div>
                            </div>
                            <template v-for="treeItemData in treeData">
                                <div v-if="treeItemData.children && treeItemData.children.length" :data-spm-module="treeItemData.type === 'city' ? 'DestinationFilter':'CategoryFilter'" :class="'search_left_template select_' + treeItemData.type">
                                    <div class="type_title">
                                        ${treeItemData.name}
                                    </div>
                                    <vue-tree :ref="'vueTree' + treeItemData.type" :tree-type="treeItemData.type" :data="treeItemData.children"
                                                :search-filter="searchFilter"
                                                :view-all-num="treeItemData.type == 'city' ? cityNum : tagNum"
                                                @choose-ok-select-tree="chooseOkSelectTree"
                                                @show-select-tree="showSelectTreeFn"
                                                @change-checked-tree="changeCheckedTree"
                                                @expand-tree="expandTree"
                                                @change-view-all="viewAllTree($event, treeItemData.type)"
                                                @close-select-tree="closeSelectTree"
                                    ></vue-tree>
                                </div>
                            </template>
                        </div>
