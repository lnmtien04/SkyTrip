_experiences_l2_tours_sightseeing.png","corner_marker_url":"","title":"Tour","type":"","business_name":"9_Tours","deep_link":"https://www.klook.com/vi/experiences/list/vietnam-tours/g13-cate9/","extra_info":null,"partner_extra_info":{"category":"Tours"},"sub_menu_list":[]},{"icon_src":"https://res.klook.com/image/upload/v1639126245/brand%20refresh%20category%20icon/desktop/category_36_experiences_l2_natural_landscapes_gardens.png","corner_marker_url":"","title":"Hoạt động ngoài trời","type":"","business_name":"15_Outdoors & sports ","deep_link":"https://www.klook.com/vi/experiences/list/vietnam-outdoor-sports-activities/g13-cate15/","extra_info":null,"partner_extra_info":{"category":"Outdoors & sports"},"sub_menu_list":[]},{"icon_src":"https://res.klook.com/image/upload/v1673857782/brand%20refresh%20category%20icon/20230116update/category_experiences_l1_spa___hotsprings_36.png","corner_marker_url":"","title":"Massages","type":"","business_name":"20_Relaxation & beauty","deep_link":"https://www.klook.com/vi/experiences/list/vietnam-massages-hot-springs/g13-cate20/","extra_info":null,"partner_extra_info":{"category":"Relaxation & beauty"},"sub_menu_list":[]},{"icon_src":"https://res.klook.com/image/upload/v1639126251/brand%20refresh%20category%20icon/desktop/category_36_more_to_explore_l1_WiFi_SIM_cards.png","corner_marker_url":"","title":"WiFi & Thẻ SIM","type":"","business_name":"58_WiFi & SIM cards","deep_link":"https://www.klook.com/vi/wifi-sim-card/?country_id=13","extra_info":null,"partner_extra_info":{"category":"WiFi & SIM cards"},"sub_menu_list":[]}],"column_menu_list":[],"publish_language":["bg_BG","bn_BD","ca_ES","cs_CZ","da_DK","de_DE","el_GR","en_AU","en_BS","en_CA","en_GB","en_HK","en_IN","en_MY","en_NZ","en_PH","en_SG","en_US","es_ES","fi_FI","fr_FR","hi_IN","hu_HU","id_ID","it_IT","ja_JP","ko_KR","ms_MY","nb_NO","nl_NL","pl_PL","pt_BR","pt_PT","ro_RO","ru_RU","si_LK","sk_SK","sv_SE","ta_IN","th_TH","tl_PH","tr_TR","vi_VN","zh_CN","zh_HK","zh_TW"],"i18n_map":{"bg_BG":"Виетнам","bn_BD":"ভিয়েতনাম","ca_ES":"Vietnam","cs_CZ":"Vietnam","da_DK":"Vietnam","de_DE":"Vietnam","el_GR":"Βιετνάμ","en_AU":"Vietnam","en_BS":"Vietnam","en_CA":"Vietnam","en_GB":"Vietnam","en_HK":"Vietnam","en_IN":"Vietnam","en_MY":"Vietnam","en_NZ":"Vietnam","en_PH":"Vietnam","en_SG":"Vietnam","en_US":"Vietnam","es_ES":"Vietnam","fi_FI":"Vietnam","fr_FR":"Viêt Nam","hi_IN":"वियतनाम","hu_HU":"Vietnám","id_ID":"Vietnam","it_IT":"Vietnam","ja_JP":"ベトナム","ko_KR":"베트남","ms_MY":"Vietnam","nb_NO":"Vietnam","nl_NL":"Vietnam","pl_PL":"Wietnam","pt_BR":"Vietname","pt_PT":"Vietname","ro_RO":"Vietnam","ru_RU":"Вьетнам","si_LK":"වියට්නාමය","sk_SK":"Vietnam","sv_SE":"Vietnam","ta_IN":"வியட்நாம்","th_TH":"ประเทศเวียดนาม","tl_PH":"Vietnam","tr_TR":"Vietnam","vi_VN":"Việt Nam","zh_CN":"越南","zh_HK":"越南","zh_TW":"越南"},"redirect_link":"","breadcrumb":{"breadcrumb":[{"deep_link":"https://www.klook.com/vi/","name":"Trang chủ "},{"deep_link":"","name":"Việt Nam","track_info":{"extra":{"destination_id":1013}}}]},"isTemplateOrTag":false,"countryNavInfo":{"bannerUrl":"https://res.klook.com/image/upload/v1773229111/destination/jgymuqrkfu86nqucikmv.jpg","rangeId":3,"countryId":13,"urlSeo":"vietnam","countryName":"Việt Nam","countryDesc":"Khám phá những thành phố & các điểm tham quan hàng đầu ở Việt Nam! Vui chơi thả ga ở Hà Nội hoặc khám phá nhiều địa điểm du lịch nổi tiếng như Vịnh Hạ Long. Đặt ngay trên Klook và hưởng ưu đãi giảm giá độc quyền! ","hotCities":[{"priority":0,"display_status":0,"card_url":"https://res.klook.com/image/upload/v1755071862/destination/lnzgvjcuxplxfmfeazah.jpg","name":"Thành phố Hồ Chí Minh","id":33,"dest_id":0,"de\u0073\u0063\u0072\u0069\u0070\u0074ion":"Thành phố Hồ Chí Minh, hay còn gọi là Sài Gòn, mang trong mình một nền văn hóa đa dạng và đặc sắc. Với hai mùa nắng mưa rõ rệt và vẻ đẹp tân cổ hài hoà, thành phố Hồ Chí Minh chắc chắn là một chặng dừng chân khó quên cho tất cả du khách.\n\nBạn có thể dành nửa ngày để tham quan Địa Đạo Củ Chi hay tìm hiểu về những khu di tích giàu ý nghĩa lịch sử trong thời kỳ Chiến Tranh Việt Nam. Hãy trải nghiệm cuộc sống gần gũi như một người dân địa phương trong chuyến tham quan Sài Gòn bằng xe máy và ghé thăm các địa danh nổi tiếng như Bưu Điện Thành Phố và Nhà Hát Thành Phố.\n\nNằm ở vị trí thuận lợi, thành phố Hồ Chí Minh là đầu mối di chuyển đến nhiều địa điểm tham quan nổi tiếng như miền Tây sông nước và vùng ven biển quyến rũ. Khám phá một khía cạnh khác của miền Nam đất nước khi bạn xuôi dòng về Đồng Bằng Sông Cửu Long, ghé thăm làng chài nổi tiếng với những ngôi nhà mái lá và cánh đồng lúa bát ngát. Đừng quên thử thưởng thức các món đặc sản theo mùa như kẹo dừa thơm ngon làm tại chỗ.\n\nVới dịch vụ trung chuyển tiện lợi như thuê xe hơi riêng, xe buýt hop on hop off, du khách dễ dàng khám phá mọi ngóc ngách của thành phố Hồ Chí Minh và nhiều hơn thế nữa. Sở hữu nền ẩm thực phong phú, thành phố Hồ Chí Minh mang đến danh sách món ăn ngon nhiều không kể xiết - từ ẩm thực đường phố tại khu chợ truyền thống đến tiệc buffet sang trọng. Khi màn đêm buông xuống, nhịp sống tại Sài Gòn trở nên sôi động hơn với đa dạng hoạt động hấp dẫn. Còn gì tuyệt vời hơn khi vi vu vào buổi tối tại các khu vực nổi tiếng như Phố Đi Bộ Nguyễn Huệ, Tháp Bitexco để hòa mình vào dòng người tấp nập. Khu trung tâm thành phố Hồ Chí Minh không thiếu những khách sạn giá rẻ và điểm lưu trú an toàn cho chuyến đi của bạn.\n\nDu lịch thành phố Hồ Chí Minh, bạn có thể tận hưởng giây phút thư giãn tại nhiều hệ thống spa cao cấp ở Sài Gòn bằng cách đặt dịch vụ tiện lợi trong “một chạm” trên Klook Vietnam. Chỉ cần vài phút lựa chọn, Klook sẽ mang đến cho bạn nhiều dịch vụ hấp dẫn và mới lạ để khám phá trọn vẹn một Sài Gòn đầy niềm vui. Du khách sẽ được trải nghiệm các hoạt động du lịch thú vị tại thành phố Hồ Chí Minh trên Klook với nhiều ưu đãi hấp dẫn mỗi ngày và quy trình đặt hàng vô cùng tiện lợi.\n\nThành phố Hồ Chí Minh hứa hẹn là một điểm tham quan du lịch đáng nhớ cho tất cả mọi người. Đặt ngay các sản phẩm trên Klook để tận hưởng những ưu đãi giới hạn và cùng gia đình, bạn bè tận hưởng những giây phút đáng nhớ tại Sài Gòn nhé.\n","location":"10.823099,106.629664","seo_url":"ho-chi-minh-city","keywords":[{"keyword":"Khám phá nông thôn","image":""},{"keyword":"Lịch sử và Văn hóa","image":""},{"keyword":"Kiến trúc ấn tượng","image":""}],"hot_activities":[{"id":123902,"instance":1,"participate":382397,"url_seo":"","video_url":"","score":4.6,"published":true,"review_total":9283,"title":"5G eSIM Việt Nam | Viettel","date_de\u0073\u0063\u0072\u0069\u0070\u0074ion":"","template_id":8,"sub_category":0,"leaf_category":639,"country_id":13,"country_code":"","city_id":34,"city_name":"","latlng":"0,0","latlng_wgs84":"","first_publish_time":"2024-07-16T14:43:40.000Z","display_package_card":0,"image_url":"","country_name":"","activity_type":"","image_url_host":"https://res.klook.com/image/upload/activities/izny7ql5ylxhdpitgvyy.jpg","published_language":["en_AU","en_PH","tl_PH","ru_RU","en_HK","en_NZ","en_MY","sv_SE","pl_PL","ja_JP","th_TH","fi_FI","en_CA","fr_FR","zh_TW","id_ID","tr_TR","ms_MY","vi_VN","en_SG","ko_KR","en_GB","pt_BR","nl_NL","en_BS","de_DE","zh_HK","en_IN","pt_PT","da_DK","it_IT","zh_CN","en_US","cs_CZ","es_ES","en_AE"],"real_lang":"","language_publish_status":0,"language_once_published":false,"viewable_platform":0,"publish_info":{"publish_status":0,"publish_status_desc":"","published_time_utc":""},"currency":"VND","package_id":0,"market_price":"4.0","sell_price":"4.0","from_price":"4.0","to_price":"147.0","spec_price":{"type":0,"desc":""},"start_time":"2026-04-19T00:00:00Z","sold_out":false,"package_count":0,"hot_state":"","participants_format":"300K+ Đã đặt","discount":0,"card_tags":{"klook_official":"Thương hiệu Klook"},"tags":[{"key":"klook_official","background_color_left":"#FF5722","background_color_right":"#FF5722","text_color":"#FFFFFF","text":"Thương hiệu Klook"}],"icon":null,"icons":[],"min_trip":0,"ysim_info":{},"is_srv_activity":false,"is_nsw_