c"},"tags":[{"key":"klook_choice","background_color_left":"#FF5722","background_color_right":"#FF5722","text_color":"#FFFFFF","text":"Klook chọn lọc"}],"icon":null,"icons":null,"min_trip":0,"ysim_info":{},"is_srv_activity":false,"is_nsw_activity":false,"detail_hotel":null,"NeedHideReview":false,"DeepLink":"activity/7448-halong-bay-day-tour-hanoi-halong-bay/","need_hide_review":false,"deeplink":"","deep_link":"/vi/activity/7448-halong-bay-day-tour-hanoi-halong-bay/","vertical_type":0,"vertical_id":0,"custom_tags":null,"tag_ids":null}]}],"city_ids":[33,34,74,486,75,130,208,207],"country_info":{"id":13,"name":"Việt Nam","de\u0073\u0063\u0072\u0069\u0070\u0074ion":"Ẩm thực với cà phê đậm đà hay bát Phở đậm vị chính là một trong những lý do thu hút du khách khắp mọi nơi đến Việt Nam. Không chỉ vậy, lịch sử hào hùng gắn liền với những địa danh như Địa Đạo Củ Chi hay những nét kiến trúc thuộc địa Pháp xưa vẫn giữ nguyên vẻ đẹp cũng là những nơi giúp bạn khám phá trọn vẹn du lịch Việt Nam.\n\nDu lịch Sài Gòn, hãy thuê ngay một chiếc xe máy để vi vu, khám phá và chinh phục những con phố đông đúc, náo nhiệt. Về Bắc Bộ, hãy đừng bỏ lỡ cơ hội đắm mình vào khung cảnh non nước hữu tình của Vịnh Hạ Long. Bạn không cần lo lắng về giá cả, bởi bạn sẽ luôn tìm được chỗ ở lý tưởng dành cho nghỉ dưỡng, đi phượt hoặc đi chơi cùng bạn bè với các mức giá hợp lý.","banner_url":"https://res.klook.com/image/upload/v1773229111/destination/jgymuqrkfu86nqucikmv.jpg","small_card_url":"https://res.klook.com/image/upload/v1773229111/destination/vbjjukfvacg1zbiyxpy2.jpg","official_languages":"Tiếng Việt","currency_list":[{"to_currency":"VND","from_currency":"VND","to_value":1,"from_value":1,"disable_rule":false,"to_currency_i18n":"Việt Nam Đồng ","exchange_rate":"1VND = 1.00VND"}],"lat_lng":"14.058324,108.277199","country_region_code":"","range_id":3,"seo_title":"Top thành phố, điểm đến và địa danh du lịch Việt Nam","seo_keyword":"việt nam, du lịch việt nam, tour du lịch việt nam, ẩm thực việt nam, 