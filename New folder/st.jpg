            <div class="header-flex-search g_ib explor g_abs navContainer">
                    <div class='h_explorContainer' data-spm-module="TopNavigation?trg=manual">
                        
    
    
    
                        <input data-galileo-click="__default" data-spm-item="SearchInput?trg=manual&typ=entry" id="h-explor" autocomplete="off" class="g_ib j_destination_search t_nowrap" placeholder="Tìm theo điểm đến, hoạt động" />
                        <svg data-galileo-click="__default" data-spm-item="SearchBtn?trg=manual&typ=entry" class="klook-symbol header-search-icon t12" id='search_icon'><use xlink:href="#icon-icon_edit_search_s"></use></svg>
                    </div>
                    <div class="city_block top_radius m_bg_white f_hidden" data-role="destination-search-box">
    
                        <div class='result_block'>
    
                        </div>
    
                        <div class="search-start f_hidden" >
                            <div v-if="searchStartABNew">
                                <select-group
                                  v-if="searchHistoryArr.length && isSearchStartShow"
                                  :title="$t('search_history')"
                                  icon-show
                                  :display-rows="1"
                                  :select-data="searchHistoryArr"
                                  :show-popover="showPopover"
                                  in-house-type="SearchStart_SearchHistory_LIST"
                                  @icon-click="deleteAllHistory"
                                  @tag-click="handleHistoryClick"></select-group>
                                <select-group
                                  v-if="hot_words && hot_words.length && isSearchStartShow"
                                  :title="$t('8040')"
                                  :display-rows="1"
                                  :select-data="hot_words"
                                  :show-popover="showPopover"
                                  in-house-type="SearchStart_HotWord_LIST"
                                  @tag-click="handleHistoryClick"></select-group>
                                <div
                                  v-if="tab_list && tab_list.length > 0"
                                  class="search-start-new-container"
                                >
                                    <div
                                      v-for="(item, index) in tab_list.slice(0, 2)"
                                      :key="index"
                                      class="hot-area"
                                    >
                                        <div class="hot-area-title">
                                            <div class="recommend-title-text">${ item.tab_name  }</div>
                                            <div class="recommend-title-bar"></div>
                                        </div>
                                        <div
                                          v-for="(data, number) in item.items"
                                          :key="data.id"
                                          class="recommend-card"
                                          :data-spm-module="`SearchStart_TopicListing_LIST?oid=${data.track_info.object_id}&ext=${encodeURIComponent(JSON.stringify(data.track_info.extra))}&idx=${number}&len=${item.items.length}`"
                                        >
                                            <large-card v-if="item.tab_type === 1" data-galileo-click="__default" data-spm-item="__default?typ=entry" :card-data="data" :number="number + 1"></large-card>
                                            <small-card v-if="item.tab_type === 2" data-galileo-click="__default" data-spm-item="__default?typ=entry" :card-data="data" :number="number + 1"></small-card>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div v-else>
                                <div
                                  v-if="searchHistoryArr.length > 0"
                                  class="search-start_history"
                                >
                                    <div class="search-start_title">${ $t('search_history') }</div>
                                    <div class="search-start_content">
                                        <div class="search-start_history-wrapper">
                                            <div class="search-start-tag">
                                                <div
                                                  v-for="(tag,index) in searchHistoryArr"
                                                  :key="index"
                                                  class="search-start-tag_item-wrapper"
                                                  :data-spm-module="`SearchStart_SearchHistory_LIST?ext=${encodeURIComponent(JSON.stringify({'KeyWord':tag }))}&idx=${index}&len=${searchHistoryArr.length}`"
                                                >
                                                <span
                                                  data-galileo-click="__default" data-spm-item="__default?typ=entry"
                                                  class="search-start-tag_item"
                                                  @click="handleHistoryClick(tag)"
                                                >
                                                    ${tag}
                                                </span>
                                                </div>
                                            </div>
                                        </div>
                                        <span @click.stop="deleteAllHistory">
                                        <svg class="klook-symbol symbol-size-16 klook-symbol-gray-800">
                                            <use xlink:href="#icon-icon_edit_delete_m"></use>
                                        </svg>
                                    </span>
                                    </div>
                                </div>
                                <div
                                  v-if="hotword && hotword.values.length > 0 "
                                  class="search-start_hot"
                                >
                                    <div class="search-start_title">
                                        ${ hotword.name }
                                        <svg class="klook-symbol symbol-size-16 svg-icon">
                                            <use xlink:href="#icon-hot_fill"></use>
                                        </svg>
                                    </div>
                                    <div class="search-start_content">
                                        <div class="search-start-tag">
                                            <div
                                              v-for="(tag,index) in hotword.values"
                                              :key="index"
                                              class="search-start-tag_item-wrapper"
                                              :data-spm-module="`SearchStart_HotWord?ext=${JSON.stringify({'KeyWord':tag.name })}&idx=${index}&len=${hotword.values.length}`"
                                            >
                                                <span
                                                  data-galileo-click="__default" data-spm-item="__default?typ=entry"
                                                  class="search-start-tag_item"
                                                  @click="handleTagClick(tag.name)"
                                                >
                                                    ${ tag.name }
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="search-start_section">
                                    <div
                                      v-if="activity && activity.values.length > 0 "
                                      class="search-start_popular-activity"
                                    >
                                        <div class="search-start_title">${ activity.name }</div>
                                        <div
                                          v-for="(activityItem,index) in activity.values.slice(0,8)"
                                          :key="index"
                                          :data-spm-module="`SearchStart_PopularActivities_LIST?oid=activity_${activityItem.id}&idx=${index}&len=${activity.values.length}`"
                                          @click="handleActivityClick(activityItem)"
                                        >
                                            <div
                                              class="search-start_popular-activity--item"
                                              data-galileo-click="__default" data-spm-item="__default?typ=entry"
                                            >
                                                <div
                                                  :style="{ backgroundImage: `url(${formatPicUrl(setNewImageSize(activityItem.image_url,'image/upload/',64,64))})` }"
                                                  class="search-start_popular-activity--image"
                                                ></div>
                                                <div class="search-start_popular-activity--content">
                                                    <div class="item_name">${ activityItem.name }</div>
                                                    <p>${ activityItem.country_name }</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div
                                      v-if="hotCategories && hotCategories.values && hotCategories.values.length > 0 "
                                      class="search-start_popular-category"
                                    >
                                        <div class="search-start_title">
                                            ${ hotCategories.name }
                                        </div>
                                        <p
                                          v-for="(value,index) in hotCategories.values.slice(0,9)"
                                          :key="index"
                                          class="search-start_popular-category--item"
                                          :data-spm-module="`SearchStart_PopularCategorys_LIST?ext=${JSON.stringify({'BusinessName':value.business_name})}&idx=${index}&len=${hotCategories.values.length}`"
                                          @click="handleHotCategoryClick(value)"
                                        >
                                        <span data-galileo-click="__default" data-spm-item="__default?typ=entry">
                                            ${ value.name }
                                        </span>
                                        </p>
                                    </div>
                                    <div
                                      v-if="city && city.values.length > 0 "
                                      class="search-start_popular-destination"
                                    >
                                        <div class="search-start_title">${ city.name }</div>
                                        <p
                                          v-for="(value,index) in city.values.slice(0,9)"
                                          :key="index"
                                          class="search-start_popular-destination--item"
                                          :data-spm-module="`SearchStart_PopularDestinations_LIST?oid=city_${value.id}&idx=${index}&len=${city.values.length}`"
                                          @click="handleHotCityClick(value)"
                                        >
                                        <span data-galileo-click="__default" data-spm-item="__default?typ=entry">
                                            ${ value.name }
                                        </span>
                                            <span>
                                            <svg v-if="value.is_current_location"
                                                 class="klook-symbol symbol-size-16 svg-icon">
                                                <use xlink:href="#icon-location_fill"></use>
                                            </svg>
                                        </span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
    
    
    
                    <!-- 只在城市页面出现 -->
                </div>
    
    
            <nav class="header-flex-nav" >
                <ul class="flex-row" id="j_top_nav">
                    <div id="nav-lang-currency-app">
                        <nav-language-currency
                            :currency="currency"
                            :language="language"
                            :render-languages='[{"title":"English (Australia)","value":"en-AU","languageCode":"EN(AU)"},{"title":"English (Canada)","value":"en-CA","languageCode":"EN(CA)"},{"title":"English (Hong Kong, SAR)","value":"en-HK","languageCode":"EN(HK)"},{"title":"English (India)","value":"en-IN","languageCode":"EN(IN)"},{"title":"English (Malaysia)","value":"en-MY","languageCode":"EN(MY)"},{"title":"English (New Zealand)","value":"en-NZ","languageCode":"EN(NZ)"},{"title":"English (Philippines)","value":"en-PH","languageCode":"EN(PH)"},{"title":"English (Singapore)","value":"en-SG","languageCode":"EN(SG)"},{"title":"English (US)","value":"en-US","languageCode":"EN(US)"},{"title":"English (UK)","value":"en-GB","languageCode":"EN(GB)"},{"title":"English (International)","value":"en","languageCode":"EN"},{"title":"简体中文","value":"zh-CN","languageCode":"ZH(CN)"},{"title":"繁體中文","value":[{"title":"香港繁體","value":"zh-HK","languageCode":"ZH(HK)"},{"title":"台灣繁體","value":"zh-TW","languageCode":"ZH(TW)"}]},{"title":"日本語","value":"ja","languageCode":"JA"},{"title":"한국어","value":"ko","languageCode":"KO"},{"title":"ไทย","value":"th","languageCode":"TH"},{"title":"Tiếng Việt","value":"vi","languageCode":"VI"},{"title":"Bahasa Indonesia","value":"id","languageCode":"ID"},{"title":"Bahasa Malaysia","value":"ms-MY","languageCode":"MS"},{"title":"Français","value":"fr","languageCode":"FR"},{"title":"Español (España)","value":"es","languageCode":"ES"},{"title":"Deutsch","value":"de","languageCode":"DE"},{"title":"Italiano","value":"it","languageCode":"IT"},{"title":"Русский","value":"ru","languageCode":"RU"},{"title":"Tagalog","value":"tl","languageCode":"TL"},{"title":"Nederlands","value":"nl","languageCode":"NL"},{"title":"Português (Portugal)","value":"pt-PT","languageCode":"PT(PT)"},{"title":"Português (Brasil)","value":"pt-BR","languageCode":"PT(BR)"},{"title":"Polski","value":"pl","languageCode":"PL"},{"title":"Svenska","value":"sv","languageCode":"SV"},{"title":"Dansk","value":"da","languageCode":"DA"}]'
                            :support-currencies="supportCurrencies"
                            @change-lang="changeLang"
                            @change-currency="changeCurrency"
                        >
                        </nav-language-currency>
                    </div>
                    <li class="j_download"><a href="/vi/tetris/appdownload/default/?ref-source=NavigationBar" data-galileo-click="__default" data-spm-item="LandingpageAppBtn">
                      <span>Mở ứng dụng</span></a></li>
                    <li style="display: none"><a id="abTest_navReferral" href="/vi/invite">Mời bạn bè</a></li>
                    <li class="j_faq"><a href="/vi/faq/?ref-source=NavigationBar" data-track-event="Help Center|Help Button Clicked on Header" data-gatag="Main Page|Help Center" data-galileo-click="__default" data-spm-item="HelpCenter">
                        <span>Trợ giúp</span></a></li>
                    <li class="g_rel recently_view_toggle f_hidden j_recently_view_toggle">
                        <a class="" href="javascript:void(0);">
                          <span>Xem gần đây</span></a>
                        <div class="recently_view_box shadow_box__4 f_hidden">
                            <div class="list j_recently_view_list">
    
                            </div>
                        </div>
                    </li>
    
    
    
                    <li id="nav_placeholder" style="min-width: 36px"></li>
                </ul>
            </nav>
        </div>
    </header>
    
    <script type="text/x-template" id="tpl_nav_user_info">
        {{#if @root._util_config.is_guest_checkout}}
            <li id="viewBooking">
                <a href="/{{@root._lang_path}}guest_booking">{{t 'guest_checkout_view_booking'}}</a>
            </li>
            {{#if @root._return_to_main_site}}
            <li id="login" class="return_to_main_site">
                <a data-track-event="Sign Up & Login|Sign In Button Clicked|Direct Clicked" data-gatag="Main Page|Sign In">{{t "header.SignIn"}}</a>
            </li>
            {{/if}}
        {{else}}
            {{#if user_info}}
            {{#user_info}}
            <li id="userInfo">
                <a href="javascript:void(0);" class="nav_user_name" style="{{#if (and @root.user_info.display_membership_entry @root.user_info.membership_style)}}border: 1.9px solid {{@root.user_info.membership_style.color}}{{/if}}">
                    <img id="userImg" src="{{get_avatar_url avatar_url}}" alt="" class="m_circle_box g_right">{{#if @root.reddot}}<span class="dot persondot"></span>{{/if}}{{#if (and @root.user_info.display_membership_entry @root.user_info.membership_style)}}<img width="20" height="20" class="profile_rewards" src="{{@root.user_info.membership_style.medal}}">{{/if}}
                </a>
                <ul class="user_info shadow_box__4 m_radius_block m_bg_white t_black g_abs f_hidden {{#if (and is_abtest credits)}}abtest_user_info{{/if}}">
                    <i class="m_triangle_up" data-gatag="My Page|My Account">
                        <i class="m_triangle_up"></i>
                    </i>
                    <li data-galileo-click="__default" data-spm-item="Booking"><a href="/{{@root._lang_path}}bookings"><svg class="klook-symbol symbol-size-24 klook-symbol-gray-800"><use xlink:href="#icon-icon_shopping_voucher_m"></use></svg>{{t "header.Bookings"}}</a></li>
                    {{#if @root.user_info.display_membership_entry}}<li data-galileo-click="__default" data-spm-item="KlookReward" class='account-rewards'><a href="javascript:void(0);"><svg class="klook-symbol symbol-size-24 klook-symbol-gray-800 rewards-icon"><use xlink:href="#icon-icon_klook_rewards"></use></svg>{{t "74786" }}</a></li>{{/if}}
                    <li data-galileo-click="__default" data-spm-item="PromoCode" class="account-promo-code"><a href="/{{@root._lang_path}}coupons"><svg class="klook-symbol symbol-size-24 klook-symbol-gray-800"><use xlink:href="#icon-icon_shopping_coupon_m"></use></svg>{{t 'promo_code.header'}}</a></li>
                    <li data-galileo-click="__default" data-spm-item="Credits" class="account-new-credits"><a href="/{{@root._lang_path}}credits"><svg class="klook-symbol symbol-size-24 klook-symbol-gray-800"><use xlink:href="#icon-icon_personal_center_credits_m"></use></svg>{{t "header.Credits"}}
                        {{#if (and is_abtest credits)}}<span class="abtest_nav_mention">{{show_credits}} {{t "abtest_user_credits_word"}}</span>{{/if}}
                    </a></li>
                    {{#evl (showGiftCardEntry @root._lang)}}
                    <li data-galileo-click="__default" data-spm-item="GiftCard" class="giftCard"><a href="/{{@root._lang_path}}klook-gift-card" class="j-nav-gift_card"><svg class="klook-symbol symbol-size-24 klook-symbol-gray-800"><use xlink:href="#icon-icon_shopping_gift_m"></use></svg>{{t "gift_card_klook"}}</a></li>
                    {{/evl}}
                    <li data-galileo-click="__default" data-spm-item="Wish"><a href="/{{@root._lang_path}}wishlist"><svg class="klook-symbol symbol-size-24 klook-symbol-gray-800"><use xlink:href="#icon-icon_social_favorite_m"></use></svg>{{t "header.WishList"}}</a></li>
                    <li data-galileo-click="__default" data-spm-item="MyReview" class="unreviewDot"><a class="user-info-review" href="/{{@root._lang_path}}my_reviews"><svg class="klook-symbol symbol-size-24 klook-symbol-gray-800"><use xlink:href="#icon-icon_shopping_review_m"></use></svg>{{t "header.Reviews"}}</a>{{#if @root.reddotset}}<span class="dot setdot"></span>{{/if}}</li>
                    <li data-galileo-click="__default" data-spm-item="Invite" class='account-new-earn-rewards'><a href="/{{@root._lang_path}}invite"><svg class="klook-symbol symbol-size-24 klook-symbol-gray-800"><use xlink:href="#icon-icon_personal_center_earn_rewards_m"></use></svg>{{t "header.ReferToFriends"}}</a></li>
                    <li data-galileo-click="__default" data-spm-item="Setting" class="accountDot"><a href="/{{@root._lang_path}}account_setting"><svg class="klook-symbol symbol-size-24 klook-symbol-gray-800"><use xlink:href="#icon-icon_edit_setting_m"></use></svg>{{t "header.AccountSetting"}}</a></li>
                    <li data-galileo-click="__default" data-spm-item="LogOut" class="user_info_last_li"><a href="javascript:;" class="logout-btn">{{t "header.LoginOut"}}</a></li>
    
                <span class="abtest_mention_warp shadow_box__4 m_radius_block m_bg_white t_black g_abs f_hidden">
                    <i class="m_triangle_up">
                        <i class="m_triangle_up"></i>
                    </i>
                    <div class="abtest_mention_warp__div--content">
                        <p>{{{t 'abtest_user_credits_mentions' show_credits}}}</p>
                    </div>
                </span>
            </li>
            {{/user_info}}
            {{else}}
            <li id="register" style="position: relative" data-galileo-click="__default" data-spm-item="Signup">
                <a href="/{{@root._lang_path}}signup" data-track-event="Sign Up & Login|Sign Up Button Clicked|Direct Sign Up" data-gatag="Main Page|Register">{{t "header.SignUp"}}</a>
                <div class="abtest_pop j_abtest_pop f_hidden">
                    <div class="abtest_pop__div--arrow_up"></div>
                    <a class="abtest_pop__a--su_button" href="/{{@root._lang_path}}signup">{{t 'header_abTest_signUp'}}</a>
                    <p class="abtest_pop__p--tip">{{t 'header_abTest_account'}}</p>
                    <a class="abtest_pop__a--login" href="/{{@root._lang_path}}signin">{{t 'header_abTest_logIn'}}</a>
                </div>
            </li>
            <li id="login" data-galileo-click="__default" data-spm-item="Login">
                <a href="/{{@root._lang_path}}signin" data-track-event="Sign Up & Login|Sign In Button Clicked|Direct Clicked" data-gatag="Main Page|Sign In">{{t "header.SignIn"}}</a>
            </li>
            {{/if}}
        {{/if}}
    </script>
    
    
    <script type="text/x-template" id="tpl_recently_view_list">
        <div class="recently-views">
        {{#recently_view}}
        {{#if (eq type 'activity')}}
        <a class="recently-views-activity recently_card"
           href="{{extra_info.deep_link}}"
           target="_blank"
           data-track-event="Others|Nav Bar Recently Viewed Activity Clicked|Activity_{{extra_info.activity_id}}"
           data-city-id="{{extra_info.city_id}}"
           data-id="{{extra_info.activity_id}}"
        >
            <img class="recently-views-activity-image lazy"
                data-original="{{set_new_image_size extra_info.image_src 'image/upload/' 160 160}}" 
            />
            <div class="recently-views-activity-image-info">
                <h3 class="title">{{ extra_info.title }}</h3>
                <ul class="price">
                    {{#if extra_info.free_text}}
                    <span>{{ extra_info.free_text }}</span>
                    {{/if}}
                    
                    {{#unless extra_info.free_text}}
                    
                    {{#if extra_info.market_price}}
                    {{#if extra_info.sell_price}}
                    {{#if (gt extra_info.market_price.amount_display extra_info.sell_price.amount_display)}}
                    <li class="priceMarket">
                        <del>
                            {{ extra_info.sell_price.symbol }}
                            {{ extra_info.market_price.amount_display }}
                        </del>
                    </li>
                    {{/if}}
                    {{/if}}
                    {{/if}}
                    
                    {{#if extra_info.sell_price}}
                    {{#if (gt extra_info.sell_price.amount_display 0)}}
                    <li>
                        <span>
                            {{ extra_info.sell_price.symbol }}
                            {{ extra_info.sell_price.amount_display }}
                        </span>
    
                        {{#if extra_info.can_immediately}}
                        <i class="klook-icon-fast" style="color: #ff5722;"></i>
                        {{/if}}
                    </li>
                    {{/if}}
                    {{/if}}
                    {{/unless}}
                </ul>
            </div>
        </a>
        {{/if}}
    
    
        {{#if (eq type 'city')}}
        <a class="recently-views-city recently_card"
           href="{{extra_info.deep_link}}"
           target="_blank"
           data-track-event="Others|Nav Bar Recently Viewed Activity Clicked|DestinationCityID_{{extra_info.city_id}}"
           data-city-id="{{extra_info.city_id}}"
           data-id="{{extra_info.city_id}}"
        >
            <img data-original="{{format_pic_url extra_info.background_src 'm_activity_card_xs_160'}}"
                 class="city-image lazy">
            <div class="city-name">
                <svg class="klook-symbol" aria-hidden="true">
                    <use xlink:href="#icon-icon_travel_location_fill_xs_color-common-black"></use>
                </svg>
                <span>{{ extra_info.title }}</span>
            </div>
        </a>
        {{/if}}
        {{/recently_view}}
    </div>
    
    </script>
    
    
    <script type="text/x-template" id="tpl_nav_search_menu">
        <div class="nav_search_menu">
        <svg class="klook-symbol nav_search_menu__icon symbol-size-20 klook-symbol-gray-900">
            <use xlink:href="#icon-icon_navigation_menu_s"></use>
        </svg>
        <span class="nav_search_menu__txt">Danh mục</span>
    
        <ul class="nav_search_menu__list">
            <div class="nav_search_menu_column">
            {{#menus}}
                {{#if (equal type 'things_to_do')}}
                    <div class="nav_search_menu__item_wrapper">
                        <a href="{{deep_link}}?is_from_nav_search_menu=true" rel="nofollow" class="nav_search_menu__item j-nav_search_menu_thing" data-track-event="Category Page|Things To Do Clicked (plan B)" data-id="{{id}}">
                            <svg class="klook-symbol nav_search_menu__item_icon nav_search_menu__icon_things">
                                <use xlink:href="#icon-{{icon_url}}"></use>
                            </svg>
                            <p class="nav_search_menu__item_txt nav_search_menu__item_txt--title">{{content}}</p>
                            <svg class="klook-symbol nav_search_menu__icon_arrow symbol-size-16 klook-symbol-gray-800">
                                <use xlink:href="#icon-icon_navigation_chevron_right_xs"></use>
                            </svg>
                        </a>
                        {{#children}}
                            <a href="{{deep_link}}&is_from_nav_search_menu=true" ref="nofollow" class="nav_search_menu__item j-nav_search_menu_thing" data-track-event="Category Page|Category Clicked|{{id}}" data-id="{{id}}">
                                <p class="nav_search_menu__item_txt">{{content}}</p>
                            </a>
                        {{/children}}
                    </div>
    
                {{else if (equal type 'wifi_and_sim_card')}}
                    <div class="nav_search_menu__item_wrapper">
                        {{#children}}
                        <a  href="{{deep_link}}"  class="nav_search_menu__item j-nav_search_menu_item" data-type="{{type}}">
                            <svg class="klook-symbol nav_search_menu__item_icon nav_search_menu__icon_wifi">
                                <use xlink:href="#icon-{{icon_url}}"></use>
                            </svg>
                            <p class="nav_search_menu__item_txt nav_search_menu__item_txt--title">{{content}}</p>
                            <svg class="klook-symbol nav_search_menu__icon_arrow symbol-size-16 klook-symbol-gray-800">
                                    <use xlink:href="#icon-icon_navigation_chevron_right_xs"></use>
                            </svg>
                        </a>
                        {{/children}}
                    </div>
    
                {{else if (equal type 'transportation')}}
                <div class="nav_search_menu__item_wrapper">
                    <a class="nav_search_menu__item">
                        <svg class="klook-symbol nav_search_menu__item_icon nav_search_menu__icon_transfer">
                            <use xlink:href="#icon-{{icon_url}}"></use>
                        </svg>
                        <p class="nav_search_menu__item_txt nav_search_menu__item_txt--title">{{content}}</p>
                    </a>
                    {{#children}}
                        <a href="{{deep_link}}" class="nav_search_menu__item j-nav_search_menu_item" data-type="{{type}}" data-id="{{id}}">
                            <p class="nav_search_menu__item_txt">{{content}}</p>
                        </a>
                    {{/children}}
                </div>
                {{/if}}
                {{/menus}}
            </div>
            <div class="nav_search_menu_column">
                    {{#menus}}
                    {{#if (equal type 'railways')}}
                    <div class="nav_search_menu__item_wrapper">
                        <a class="nav_search_menu__item">
                            <svg class="klook-symbol nav_search_menu__item_icon nav_search_menu__icon_wifi">
                                <use xlink:href="#icon-{{icon_url}}"></use>
                            </svg>
                            <p class="nav_search_menu__item_txt nav_search_menu__item_txt--title">{{content}}</p>
                        </a>
                        {{#children}}
                            <a href="{{deep_link}}" class="nav_search_menu__item j-nav_search_menu_item" data-type="{{type}}">
                                <p class="nav_search_menu__item_txt">{{content}}</p>
                            </a>
                        {{/children}}
                    </div>
                    {{else if (equal type 'hotel_vertical')}}
                    <div class="nav_search_menu__item_wrapper">
                        <a class="nav_search_menu__item j-nav_search_menu_item" href="{{deep_link}}?is_from_nav_search_menu=true" target="_blank"  data-type="{{type}}">
                            <svg class="klook-symbol nav_search_menu__item_icon nav_search_menu__icon_hotel">
                                <use xlink:href="#icon-{{icon_url}}"></use>
                            </svg>
                            <p class="nav_search_menu__item_txt nav_search_menu__item_txt--title">{{content}}</p>
                            <svg class="klook-symbol nav_search_menu__icon_arrow symbol-size-16 klook-symbol-gray-800">
                                <use xlink:href="#icon-icon_navigation_chevron_right_xs"></use>
                            </svg>
                        </a>
                    </div>
                    {{else if (equal type 'fnb')}}
                    <div class="nav_search_menu__item_wrapper">
                        <a class="nav_search_menu__item j-nav_search_menu_item" href="{{deep_link}}" target="_blank"  data-type="{{type}}">
                            <svg class="klook-symbol nav_search_menu__item_icon nav_search_menu__icon_fnb">
                                <use xlink:href="#icon-{{icon_url}}"></use>
                            </svg>
                            <p class="nav_search_menu__item_txt nav_search_menu__item_txt--title">{{content}}</p>
                            <svg class="klook-symbol nav_search_menu__icon_arrow symbol-size-16 klook-symbol-gray-800">
                                <use xlink:href="#icon-icon_navigation_chevron_right_xs"></use>
                            </svg>
                        </a>
                    </div>
                    {{/if}}
                    {{/menus}}
            </div>
            
        </ul>
    </div>
    </script>
    
    <script type="text/x-template" id="tpl_city_country_list">
        {{#data}}
        {{#each travel_services}}
            {{#if (equal type 'chinarail')}}
            <div class='search_list' data-spm-module="SearchSuggest_LIST?oid=category_12&idx={{@index}}&len={{../totalLength}}">
                {{#if (equal keyword_level 2)}}
                <a  href="/{{@root._lang_path}}search/?query={{url_encode name}}"
                    data-galileo-click="__default" data-spm-item="__default?typ=entry"
                    data-role="suggest-travel_services"
                    data-vertical-type="China Rail Vertical Page"
                    data-id="{{id}}"
                    class="j-suggest-travel_service align_center"
                >
                {{else}}
                <a href="/{{@root._lang_path}}china-train-ticket/"
                   data-galileo-click="__default" data-spm-item="__default?typ=entry"
                   data-role="suggest-travel_services"
                   data-vertical-type="China Rail Vertical Page"
                   data-id="{{id}}"
                   class="j-suggest-travel_service align_center"
                >
                {{/if}}
                    <div class="search_list_svg">
                        <svg class="klook-symbol search_list_travel_service__icon" aria-hidden="true">
                            <use xlink:href="#icon-rail-suggest"></use>
                        </svg>
                    </div>
                    <span class="t_black w400 j-suggest-travel_service">{{name}}</span>
                </a>
            </div>
            {{/if}}
    
            {{#if (equal type 'europerail')}}
            <div class='search_list' data-spm-module="SearchSuggest_LIST?oid=category_11&idx={{@index}}&len={{../totalLength}}">
                {{#if (equal keyword_level 2)}}
                <a  href="/{{@root._lang_path}}search/?query={{url_encode name}}"
                    data-role="suggest-travel_services"
                    data-vertical-type="Europe Rail Vertical Page"
                    data-id="{{id}}"
                    data-galileo-click="__default" data-spm-item="__default?typ=entry"
                    class="j-suggest-travel_service align_center"
                >
                {{else}}
                <a href="/{{@root._lang_path}}europe-rail/"
                   data-role="suggest-travel_services"
                   data-vertical-type="Europe Rail Vertical Page"
                   data-id="{{id}}"
                   class="j-suggest-travel_service align_center"
                   data-galileo-click="__default" data-spm-item="__default?typ=entry"
                >
                {{/if}}
                    <div class="search_list_svg">
                        <svg class="klook-symbol search_list_travel_service__icon" aria-hidden="true">
                            <use xlink:href="#icon-rail-suggest"></use>
                        </svg>
                    </div>
                    <span class="t_black w400 j-suggest-travel_service">{{name}}</span>
                </a>
            </div>
            {{/if}}
    
            {{#if (equal type 'airport_transfers')}}
            <div class='search_list' data-spm-module="SearchSuggest_LIST?oid=category_13&idx={{@index}}&len={{../totalLength}}">
                {{#if (equal keyword_level 2)}}
                <a  href="/{{@root._lang_path}}search/?query={{url_encode name}}"
                    data-role="suggest-travel_services"
                    data-vertical-type="Airport Transfers Vertical Page"
                    data-id="{{id}}"
                    data-galileo-click="__default" data-spm-item="__default?typ=entry"
                    class="j-suggest-travel_service align_center"
                >
                {{else}}
                <a href="/{{@root._lang_path}}airport-transfers/"
                   data-role="suggest-travel_services"
                   data-vertical-type="Airport Transfers Vertical Page"
                   data-id="{{id}}"
                   data-galileo-click="__default" data-spm-item="__default?typ=entry"
                   class="j-suggest-travel_service align_center"
                >
                {{/if}}
                    <div class="search_list_svg">
                        <svg class="klook-symbol search_list_travel_service__icon" aria-hidden="true">
                            <use xlink:href="#icon-airport-transfers-suggest-icon"></use>
                        </svg>
                    </div>
                    <span class="t_black w400 j-suggest-travel_service">{{name}}</span>
                </a>
            </div>
            {{/if}}
            <!-- XXX: car rental icon -->
            {{#if (equal type 'car_rental')}}
            <div class='search_list'data-spm-module="SearchSuggest_LIST?oid=category_15&idx={{@index}}&len={{../totalLength}}">
                {{#if (equal keyword_level 2)}}
                <a href="/{{@root._lang_path}}search/?query={{url_encode name}}"
                   data-role="suggest-travel_services"
                   data-vertical-type="Car Rental"
                   data-id="{{id}}"
                   class="j-suggest-travel_service align_center"
                   data-galileo-click="__default" data-spm-item="__default?typ=entry"
                >
                {{else}}
                <a href="/{{@root._lang_path}}car-rentals/"
                   data-role="suggest-travel_services"
                   data-vertical-type="Car Rental"
                   data-id="{{id}}"
                   class="j-suggest-travel_service align_center"
                   data-galileo-click="__default" data-spm-item="__default?typ=entry"
                >
                {{/if}}
                    <div class="search_list_svg">
                        <svg class="klook-symbol search_list_travel_service__icon" aria-hidden="true">
                            <use xlink:href="#icon-nav-car-rental-l"></use>
                        </svg>
                    </div>
                    <span class="t_black w400 j-suggest-travel_service">{{name}}</span>
                </a>
            </div>
            {{/if}}
    
            {{#if (equal type 'intercity')}}
            <div class='search_list' data-spm-module="SearchSuggest_LIST?oid=category_5&idx={{@index}}&len={{../totalLength}}">
                {{#if (equal keyword_level 2)}}
                <a href="/{{@root._lang_path}}search/?query={{url_encode name}}"
                   data-role="suggest-travel_services"
                   data-vertical-type="Intercity buses"
                   data-id="{{id}}"
                   class="j-suggest-travel_service align_center"
                   data-galileo-click="__default" data-spm-item="__default?typ=entry"
                >
                {{else}}
                <a href="/{{@root._lang_path}}buses/"
                   data-role="suggest-travel_services"
                   data-vertical-type="Intercity buses"
                   data-id="{{id}}"
                   class="j-suggest-travel_service align_center"
                   data-galileo-click="__default" data-spm-item="__default?typ=entry"
                >
                {{/if}}
                    <div class="search_list_svg">
                        <svg class="klook-symbol search_travel_service__icon t_black t24" aria-hidden="true">
                            <use xlink:href="#icon-bus-colorful"></use>
                        </svg>
                    </div>
                    <span class="t_black w400 j-suggest-travel_service">{{name}}</span>
                </a>
            </div>
            {{/if}}
            {{#if (equal type 'ferry')}}
            <div class='search_list' data-spm-module="SearchSuggest_LIST?oid=category_3&idx={{@index}}&len={{../totalLength}}">
                {{#if (equal keyword_level 2)}}
                <a  href="/{{@root._lang_path}}search/?query={{url_encode name}}"
                    data-role="suggest-travel_services"
                    data-vertical-type="Thailand Ferry"
                    data-id="{{id}}"
                    class="j-suggest-travel_service align_center"
                    data-galileo-click="__default" data-spm-item="__default?typ=entry"
                >
                {{else}}
                <a  href="/{{@root._lang_path}}ferry/Thailand/"
                    data-role="suggest-travel_services"
                    data-vertical-type="Thailand Ferry"
                    data-id="{{id}}"
                    class="j-suggest-travel_service align_center"
                    data-galileo-click="__default" data-spm-item="__default?typ=entry"
                >
                {{/if}}
                    <div class="search_list_svg">
                        <svg class="klook-symbol search_travel_service__icon t_black t24" aria-hidden="true">
                            <use xlink:href="#icon-ferry-colorful"></use>
                        </svg>
                    </div>
                    <span class="t_black w400 j-suggest-travel_service">{{name}}</span>
                </a>
            </div>
            {{/if}}
            {{#if (equal type 'wifi')}}
            <div class='search_list' data-spm-module="SearchSuggest_LIST?oid=category_7&idx={{@index}}&len={{../totalLength}}">
                {{#if (equal keyword_level 2)}}
                <a  href="/{{@root._lang_path}}search/?query={{url_encode name}}"
                    data-role="suggest-travel_services"
                    data-vertical-type="WiFi & SIM"
                    data-id="{{id}}"
                    class="j-suggest-travel_service align_center"
                    data-galileo-click="__default" data-spm-item="__default?typ=entry"
                >
                {{else}}
                <a  href="/{{@root._lang_path}}wifi-sim-card/"
                    data-role="suggest-travel_services"
                    data-vertical-type="WiFi & SIM"
                    data-id="{{id}}"
                    class="j-suggest-travel_service align_center"
                    data-galileo-click="__default" data-spm-item="__default?typ=entry"
                >
                {{/if}}
                    <div class="search_list_svg">
                        <svg class="klook-symbol search_travel_service__icon t_black t24" aria-hidden="true">
                            <use xlink:href="#icon-wifi-suggest-2"></use>
                        </svg>
                    </div>
                    <span class="t_black w400 j-suggest-travel_service">{{name}}</span>
                </a>
            </div>
            {{/if}}
            {{#if (equal type 'ysim_buy')}}
                <div class='search_list' data-spm-module="SearchSuggest_LIST?oid=category_9&idx={{@index}}&len={{../totalLength}}">
                    {{#if (equal keyword_level 2)}}
                    <a data-galileo-click="__default" data-spm-item="__default?typ=entry" href="/{{@root._lang_path}}search/?query={{url_encode name}}"  data-role="suggest-travel_services" data-vertical-type="YSIM" data-id="{{id}}" class="j-suggest-travel_service align_center">
                    {{else}}
                        <a data-galileo-click="__default" data-spm-item="__default?typ=entry" href="/{{@root._lang_path}}activity/{{id}}"  data-role="suggest-travel_services" data-vertical-type="YSIM" data-id="{{id}}" class="j-suggest-travel_service align_center">
                    {{/if}}
                        <div class='search_list_travel_service'>
                            <div class="search_list_svg">
                                <svg class="klook-symbol search_list_travel_service__icon" aria-hidden="true">
                                    <use xlink:href="#icon-ysimcard-suggest"></use>
                                </svg>
                            </div>
                            <p class='search_list_travel_service__name'>{{name}}</p>
                        </div>
                    </a>
                </div>
            {{/if}}
            {{#if (equal type 'ysim_top_up')}}
                <div class='search_list' data-spm-module="SearchSuggest_LIST?oid=category_9&idx={{@index}}&len={{../totalLength}}">
                    {{#if (equal keyword_level 2)}}
                    <a data-galileo-click="__default" data-spm-item="__default?typ=entry"
                        href="/{{@root._lang_path}}search/?query={{url_encode name}}"
                        data-role="suggest-travel_services"
                        data-vertical-type="YSIM Top Up"
                        data-id="{{id}}"
                        class="j-suggest-travel_service align_center">
                    {{else}}
                    <a  data-galileo-click="__default" data-spm-item="__default?typ=entry"
                        href="/{{@root._lang_path}}activity/{{id}}"
                        data-role="suggest-travel_services"
                        data-vertical-type="YSIM Top Up"
                        data-id="{{id}}"
                        class="j-suggest-travel_service align_center"
                    >
                    {{/if}}
                        <div class='search_list_travel_service'>
                            <div class="search_list_svg">
                                <svg class="klook-symbol search_list_travel_service__icon" aria-hidden="true">
                                    <use xlink:href="#icon-ysimcard-suggest"></use>
                                </svg>
                            </div>
                            <p class='search_list_travel_service__name'>{{name}}</p>
                        </div>
                    </a>
                </div>
            {{/if}}
    
            {{#if (equal type 'hotel_vertical')}}
            <div class='search_list' data-spm-module="SearchSuggest_LIST?oid=category_16&idx={{@index}}&len={{../totalLength}}">
                {{#if (equal keyword_level 2)}}
                <a href="/{{@root._lang_path}}search/?query={{url_encode name}}"
                   data-role="suggest-travel_services"
                   data-vertical-type="Hotel White Label"
                   data-id="{{id}}"
                   class="j-suggest-travel_service align_center"
                   data-galileo-click="__default" data-spm-item="__default?typ=entry"
                >
                {{else}}
                <a href="/{{@root._lang_path}}hotels/"
                   data-role="suggest-travel_services"
                   data-vertical-type="Hotel White Label"
                   data-id="{{id}}"
                   class="j-suggest-travel_service align_center"
                   data-galileo-click="__default" data-spm-item="__default?typ=entry"
                >
                {{/if}}
                    <div class="search_list_svg">
                        <svg class="klook-symbol search_list_travel_service__icon" aria-hidden="true">
                            <use xlink:href="#icon-nav-hotel-top"></use>
                        </svg>
                    </div>
                    <span class="t_black w400 j-suggest-travel_service">{{name}}</span>
                </a>
            </div>
            {{/if}}
        {{/each}}
    
        {{#each countries}}
        <div class='search_list' data-spm-module="SearchSuggest_LIST?oid=country_{{id}}&idx={{addAll @index ../travelServicesLength}}&len={{../totalLength}}">
            {{#if (equal keyword_level 2)}}
            <a rel="nofollow"
                href="/{{@root._lang_path}}search/?query={{url_encode name}}"
                data-role="suggest-country"
                data-name="{{name}}"
                data-id="{{id}}"
                class="align_center"
            >
            {{else}}
            <a rel="nofollow"
                href="/{{@root._lang_path}}coureg/{{id}}-{{seo}}-things-to-do/"
                data-role="suggest-country"
                data-name="{{name}}"
                data-id="{{id}}"
                class="align_center"
            >
            {{/if}}
                <div class="search_list_svg">
                    <svg class="klook-symbol search_list_travel_service__icon" aria-hidden="true">
                        <use xlink:href="#icon-icon-map"></use>
                    </svg>
                </div>
                <span class="t_black w400 j-suggest-travel_service">{{name}}</span>
            </a>
        </div>
        {{/each}}
        {{#each cities}}
        <div class="search_list" data-spm-module="SearchSuggest_LIST?oid=city_{{id}}&idx={{addAll @index ../travelServicesLength ../countriesLength}}&len={{../totalLength}}">
            {{#if (equal keyword_level 2)}}
            <a href="/{{@root._lang_path}}search/?query={{url_encode city_name}}"
               data-role="suggest-city"
               data-url-seo="{{seo}}"
               data-id="{{id}}"
               class="align_center"
            >
            {{else}}
            <a  href="/{{@root._lang_path}}city/{{id}}-{{seo}}-things-to-do/#krt={{../stat.klook_referral_type}}&krid={{../stat.klook_referral_id}}"
                data-role="suggest-city"
                data-url-seo="{{seo}}"
                data-id="{{id}}"
                class="align_center">
            {{/if}}
                {{#if (eq city_type 'rail')}}
                <div class="search_list_svg">
                    <svg class="klook-symbol search_list_travel_service__icon" aria-hidden="true">
                        <use xlink:href="#icon-rail-suggest"></use>
                    </svg>
                </div>
                {{else}}
                <div class="search_list_svg">
                    <svg class="klook-symbol search_list_travel_service__icon" aria-hidden="true">
                        <use xlink:href="#icon-icon-map"></use>
                    </svg>
                </div>
                {{/if}}
                <div class="search_list_city">
                    <span class="t_black w400">{{city_name}}</span>
                    <p class="t_gray">{{country_name}}</p>
                </div>
            </a>
        </div>
        {{/each}}
    
        {{#each campaign_pages}}
        <div class="search_list" data-spm-module="SearchSuggest_LIST?oid=campaign_{{id}}&idx={{addAll @index ../travelServicesLength ../countriesLength ../citiesLength}}&len={{../totalLength}}">
            <a href="{{url}}"
               data-role="suggest-campaign"
               data-id="{{id}}"
               class="align_center search_list_padding"
               data-galileo-click="__default" data-spm-item="__default?typ=entry"
            >
                <div class="search-pic" style="background-image: url('{{format_pic_url ( set_new_image_size image_url 'image/upload/' 160 160 )}}')" data-original="{{format_pic_url ( set_new_image_size image_url 'image/upload/' 160 160 )}}"></div>
                <span class="t_black w400 t_nowrap">{{title}}</span>
            </a>
        </div>
        {{/each}}
    
        {{#each activities}}
        <div class="search_list" data-spm-module="SearchSuggest_LIST?oid=activity_{{id}}&idx={{addAll @index ../travelServicesLength ../countriesLength ../citiesLength ../campaignPageLength}}&len={{../totalLength}}">
            {{#if (equal keyword_level 2)}}
            <a href="/{{@root._lang_path}}search/?query={{url_encode title}}"
               data-role="suggest-activity"
               data-url-seo="{{seo}}"
               data-id="{{id}}"
               class="align_center search_list_padding"
               data-galileo-click="__default" data-spm-item="__default?typ=entry"
            >
            {{else}}
            <a  {{#if deep_link}}
                href="{{deep_link}}"
                {{else}}
                href="/{{@root._lang_path}}activity/{{id}}-{{url_seo}}/#krt={{../stat.klook_referral_type}}&krid={{../stat.klook_referral_id}}"
                {{/if}}
                data-role="suggest-activity"
                data-url-seo="{{url_seo}}"
                data-id="{{id}}"
                class="align_center"
                data-galileo-click="__default" data-spm-item="__default?typ=entry"
            >
            {{/if}}
                <div class="search-pic" style="background-image: url('{{format_pic_url ( set_new_image_size image_url_host 'image/upload/' 160 160 )}}')" data-original="{{format_pic_url ( set_new_image_size image_url_host 'image/upload/' 160 160 )}}"></div>
    
                <div class="search_list_city">
                    <span class="t_black w400 t_nowrap">{{title}}</span>
                    <p class=" t_gray">{{city_name}}</p>
                </div>
            </a>
        </div>
        {{/each}}
    {{/data}}
    
    </script>
    
    <script type="text/x-template" id="tpl_city_country_list_new">
        {{#data}}
    {{#each data}}
    <div class="search_list" data-spm-module="SearchSuggest_LIST?oid={{tracking_info.object_id}}&ext={{encodeParams tracking_info.extra}}&idx={{addAll @index ../travelServicesLength ../countriesLength ../citiesLength ../campaignPageLength}}&len={{../totalLength}}">
      <a
        href="{{url}}"
        data-role="suggest-activity"
        data-id="{{id}}"
        class="align_center"
        data-galileo-click="__default" data-spm-item="__default?typ=entry"
        data-type-id="{{type}}"
        data-title="{{title}}"
      >
        <div class="search-pic" style="background-image: url('{{format_pic_url ( set_new_image_size icon_url 'image/upload/' 160 160 )}}')" data-original="{{format_pic_url ( set_new_image_size icon_url 'image/upload/' 160 160 )}}"></div>
    
        <div class="search_list_city">
          <span class="t_black t_nowrap">{{title}}</span>
          <p class=" t_gray">{{sub_title}}</p>
        </div>
      </a>
    </div>
    {{/each}}
    {{/data}}
    
    </script>
    
    <script type="text/x-template" id="tpl_city_country_cate">
        {{#unless hide_search}}
    <div class="t_mid search_box g_rel {{class_name}}">
        <input class="t16 j_destination_search" type="text" placeholder="{{#if hint_text}}{{hint_text}}{{else}}Tìm điểm đến{{/if}}">
        <i class="klook-icon-search t_gray g_v_c_mid t24"></i>
        <i class="icon-clear g_v_mid t24"></i>
        <i class="klook-icon-close g_v_mid t22"></i>
    </div>
    {{/unless}}
    <div class="j_city_country {{class_name}}" data-spm-module="ChangeDestination">
        <div class="left g_ib">
            {{#if show_hotdest}}
            <div class="list t_v_mid_box cur" data-role="eat">
                <div class="t_v_mid">
                    <div class="top"><b>ĐIỂM ĐẾN HÀNG ĐẦU</b></div>
                </div>
                <i class="triangle_right g_v_mid f_hidden"></i>
            </div>
            {{/if}}
    
            {{#destination_guide_menu_list}}
                {{#if (or (gt 5 @index) (eq 5 @index))}}
            <div class="list t_v_mid_box
            {{#unless ../show_hotdest}}
            {{#if (eq @index 0) }}cur{{/if}}
            {{/unless}}
            " data-role="eat">
                <div class="t_v_mid">
                    <div class="top"><b>{{menu_name}}</b></div>
    
                    <div class="bottom">
                        {{#popular_area_name_list}}
                            {{#if (or (gt 1 @index) (eq 1 @index))}}
                                <span>{{this}}</span>
                            {{/if}}
                        {{/popular_area_name_list}}
                    </div>
    
                </div>
                <i class="triangle_right g_v_mid f_hidden"></i>
            </div>
                {{/if}}
            {{/destination_guide_menu_list}}
        </div>
    
        <div class="right g_ib g_right t14" style="max-height: {{#if show_hotdest}}406px;{{else}}348px;{{/if}}overflow-y: auto;">
            {{#if show_hotdest}}
            <div data-role="cate" >
                <div class="list">
                    {{#popular_area_list}}
                    <a href="{{klook_area_url}}"
                       data-galileo-click="__default" data-spm-item='Destination?typ=entry&oid=klook_id_{{klook_id}}&ext={"LinkURL": "{{url_encode klook_area_url}}"}'
                       data-role="hot-destination"
                       data-id="{{klook_id}}"
                       class="m_bg m_radius_box"
                       style="background-image:url('{{format_pic_url ( set_new_image_size image_url 'image/upload/' 260 148 )}}')"
                       >
                       <p class="t14 t_white">{{klook_area_name}}</p>
                    </a>
                    {{/popular_area_list}}
                </div>
            </div>
            {{/if}}
    
            {{#destination_guide_menu_list}}
            <div data-role="cate"
                 {{#if ../show_hotdest}}
                 class="f_hidden"
                {{else}}
                {{#if (gt @index 0) }} class="f_hidden" {{/if}}
                {{/if}}
                >
                {{#test (t "select_country_region") "select_country_region" type='neq' }}
                    <div class="label">Chọn quốc gia hay điểm đến</div>
                {{/test}}
                {{#if (eq @root._lang 'zh-CN')}}
                <div style="padding:10px 0; color:#333;"><b>国家/地区 </b></div>
                {{/if}}
                {{#sub_menu_list}}
                {{#if (eq country_id 54)}}
                    <a href="/{{@root._lang_path}}europe-rail">
                        <span class="europe-rail">
                            <svg class="klook-symbol t24 t_black er_station"><use xlink:href="#icon-er_station"></use></svg>
                            <span class="station_text">Vé tàu Châu Âu </span>
                        </span>
                    </a>
                {{/if}}
                <div class="list">
                    <div class="_left g_ib g_left"><b><a rel="nofollow" class="countryNav" href="{{klook_area_url}}" data-role="top-country" data-country-name="{{klook_area_name}}" data-country-id="{{klook_id}}">{{klook_area_name}}</a></b></div>
    
                    <div class="_right g_ib">
                        {{#leaf_menu_list}}
                            <a href="{{klook_area_url}}"
                                data-role="top-destination"
                                data-id="{{klook_id}}"
                                data-galileo-click="__default" data-spm-item='Destination?typ=entry&oid=klook_id_{{klook_id}}&ext={"LinkURL": "{{url_encode klook_area_url}}"}'
                            >
                            {{klook_area_name}}
                            </a>
                        {{/leaf_menu_list}}
                    </div>
    
                </div>
                {{/sub_menu_list}}
            </div>
            {{/destination_guide_menu_list}}
    
            <div class="over_block t_main f_hidden">
                Cuộn xuống để xem thêm
            </div>
        </div>
    
    </div>
    
    <div class="result t16 g_rel f_hidden j_result {{class_name}}">
        <div class="f_hidden j_has_result">
            <p class="t_gray search_title">Kết quả tìm kiếm </p>
            <div class="res_list"></div>
        </div>
        <div class="no_result g_v_c_mid t16 t_mid f_hidden j_no_result">
            <p class="t_gray">Không có kết quả phù hợp </p>
            <a href="javascript:;" class="m_radius_box m_border_gray more g_ib j_reset t14">Xem các điểm đến khác</a>
        </div>
    </div>
    
    </script>
    
    <script type="text/x-template" id="tpl_city_country_loading">
        <div class='loading_city_country '>
            <div class="uil-ring-css"><div></div></div>
        </div>
    </script>
    <script  type="text/x-template" id="tpl_nav_shopping_content">
        <ul class="g_rel m_bg_white">
    <i class="m_triangle_up g_c_mid">
        <i class="m_triangle_up"></i>
    </i>
    
    {{#items}}
    <li data-spm-module="ShoppingCartBox_Activity_LIST?oid=activity_{{activity_id}}&idx={{@index}}&len={{../items.length}}">
    <a data-galileo-click="__default" data-spm-item="__default?typ=entry" href="/{{@root._lang_path}}activity/{{activity_id}}-{{seo_url}}/" data-track-event="Shopping Cart|Activity Clicked On The Shopping Cart Window|{{activity_id}}">
        <div class="g_ib g_left">
            <img src="{{format_pic_url (set_image_size activity_image_url 132 100)}}" alt="">
        </div>
        <div class="g_ib">
            <p class="t_black title webpack_box_orient">{{activity_name}}</p>
            {{#if (or (isWifiSim activity_template_id) (isYsim activity_template_id))}}
            	{{#if (isWifi activity_template_id)}}
    	            {{#if booking_days}}
    	            <p class='total_date t_gray'>{{{t 'wifi_charge_for_days' booking_days}}}</p>
    	            {{/if}}
    	            {{#if pickup_time_new}}
    	            <p class="pickUpDate t_gray">Ngày nhận/Ngày chuyển phát:<span>{{format_standard_date_duration_new pickup_time_new @root._lang}}</span></p>
    	            {{/if}}
    	            {{#if return_time_new}}
    	            <p class="pickUpDate t_gray">Ngày trả thiết bị:<span>{{format_standard_date_duration_new return_time_new @root._lang}}</span></p>
    	            {{/if}}
    	        {{else if (isSim activity_template_id)}}
    	            {{#if pickup_time_new}}
    	            <p class="pickUpDate t_gray">Ngày nhận/Ngày chuyển phát:<span>{{format_standard_date_duration_new pickup_time_new @root._lang}}</span></p>
    	            {{/if}}
                {{else if (isYsim activity_template_id)}}
                    {{#if pickup_time_new}}
                        <p class="pickUpDate t_gray">Ngày Nhận:<span>{{format_standard_date_duration_new pickup_time_new @root._lang}}</span></p>
                    {{/if}}
    	        {{/if}}
    	        {{#if package_specs}}
                    <p class="pack_name t_gray">{{concatHtmlWifi package_specs 'attr_name' ' · '}}{{#pre_other_info}} · {{getPreOtherContent type_hint content position}}{{/pre_other_info}}</p>
                {{/if}}
            {{else}}
                <p class="t_black t_nowrap">{{package_name}}</p>
                <!-- [fnb openticket]  -->
                {{#if (and (isFNB activity_template_id)  (eq ticket_type 0))}}
                <p class="t_gray t_nowrap">Có thể sử dụng mọi lúc trong hạn sử dụng</p>
                {{else if (isHotelVoucher activity_template_id)}}
                    <p class="hotel_card_validate_date t_nowrap">Hạn sử dụng Voucher: <span>{{format_standard_date_new hotel_begin_time @root._lang 2}} - {{format_standard_date_new hotel_end_time @root._lang 2}}</span></p>
                    </p>
                {{else}}
                <p class="t_gray t_nowrap">
                    Ngày : {{formatDateDesc}}
                </p>
                {{/if}}
    
                <!-- [fnb openticket]  -->
    	        <p class="t_gray t_nowrap">
                    Đơn vị :{{#price_items}}
    	            {{count}} {{name}}&nbsp;&nbsp;&nbsp;
    	            {{/price_items}}
    	        </p>
            {{/if}}
            <p class="t_main">{{@root._currency_symbo}} {{formatPriceThousands ticket_sell_price}}</p>
        </div>
    </a>
    </li>
    {{/items}}
    </ul>
    <div class="bottom_box m_bg_white">
        <div class="sum_box">
            <p class="t_black t14">{{t 'global.shoppingcart.sum' items.length}}</p>
            <p class="t_main t16 t_nowrap">{{_currency_symbo}} {{formatPriceThousands sum}}</p>
        </div>
        <div class="klk_spm_module_box klk_spm_module_box--auto" data-spm-module="ShoppingCartBox_GoTo">
            <button class="m_btn_main j_nav_shopcart t16" data-galileo-click="__default" data-spm-item="__default?typ=entry" style="width: 100%;">Xem giỏ hàng </button>
        </div>
    </div>
    
    </script>
    <script type="text/x-template" id="tpl_after_signup_alert">
        {{#if haslink}}
        <div class="after_signup_alert haslink">
        {{else}}
        <div class="after_signup_alert">
        {{/if}}
            <svg class="klook-icon"><use xlink:href="#icon-confirm-color-customizable"></use></svg>
            <p>
                {{{detail}}}
            </p>
            {{#if haslink}}
            <i class="klook-icon-close"></i>
            {{/if}}
        </div>
    </script>



