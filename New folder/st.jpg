:"Ưu đãi xuân"}],"icon":null,"icons":null,"min_trip":0,"ysim_info":{},"is_srv_activity":false,"is_nsw_activity":false,"detail_hotel":null,"NeedHideReview":false,"DeepLink":"activity/49298-interbus-lines-bus-ticket-hanoi-sapa/","need_hide_review":false,"deeplink":"","deep_link":"/vi/activity/49298-interbus-lines-bus-ticket-hanoi-sapa/","vertical_type":0,"vertical_id":0,"custom_tags":null,"tag_ids":null}]},{"priority":0,"display_status":0,"card_url":"https://res.klook.com/image/upload/cities/rxqumcihtzatvhcnbedi.jpg","name":"Đà Nẵng","id":74,"dest_id":0,"de\u0073\u0063\u0072\u0069\u0070\u0074ion":"Đà Nẵng, một đô thị ven biển năng động ở miền Trung Việt Nam, đã trở thành một viên ngọc quý theo đúng nghĩa của nó, tự hào với những bãi biển hoang sơ, những ngọn đồi xanh tươi và một bầu không khí hiện đại nhưng vẫn thư thái. Đường chân trời của thành phố được tô điểm bởi những địa danh biểu tượng như Cầu Vàng hùng vĩ trên Bà Nà Hills và Cầu Rồng ngoạn mục, nơi phun lửa vào một số buổi tối. Ngoài ra, du khách có thể khám phá Ngũ Hành Sơn huyền bí, một cụm năm đỉnh núi đá vôi với nhiều hang động và đền thờ Phật giáo, hoặc thư giãn trên bãi biển Mỹ Khê nổi tiếng với bãi cát mịn và làn nước trong vắt. Những người yêu thích hoạt động ngoài trời có thể khám phá bán đảo Sơn Trà, nơi cây xanh tươi tốt và tượng Phật Bà Quan Âm cao chót vót đang chờ đón, trong khi những tín đồ mua sắm và ẩm thực sẽ thích thú dạo quanh Chợ Hàn nhộn nhịp và thưởng thức những món ăn địa phương yêu thích bên bờ sông. Chuyến đi đến Đà Nẵng sẽ không trọn vẹn nếu thiếu chuyến viếng thăm Thánh địa Mỹ Sơn, một trong những Di sản Thế giới được UNESCO công nhận của Việt Nam. Với vô số di tích đền thờ lịch sử và các tác phẩm điêu khắc đá, đây thực sự là một cảnh tượng đáng chiêm ngưỡng! Với sự pha trộn giữa vẻ đẹp thiên nhiên, nét văn hóa đặc sắc và nét quyến rũ hiện đại, Đà Nẵng mời gọi du khách khám phá những điểm đến đa dạng.","location":"16.054407,108.202167","seo_url":"da-nang","keywords":[{"keyword":"Khu di tích thế giới","image":""},{"keyword":"Kiến trúc ấn tượng","image":""},{"keyword":"Kỳ quan thiên nhiên","image":""}],"hot_activities":[{"id":13283,"instance":1,"participate":1599092,"url_seo":"","video_url":"","score":4.6,"published":true,"review_total":34005,"title":"Vé Cáp Treo Sun World Ba Na Hills Đà Nẵng","date_de\u0073\u0063\u0072\u0069\u0070\u0074ion":"","template_id":1,"sub_category":0,"leaf_category":521,"country_id":13,"country_code":"","city_id":74,"city_name":"","latlng":"16.026515,108.032798","latlng_wgs84":"","first_publish_time":"2018-08-06T11:39:41.000Z","display_package_card":0,"image_url":"","country_name":"","activity_type":"","image_url_host":"https://res.klook.com/image/upload/activities/np2kfk6khyd2iayoguhe.jpg","published_language":["pl_PL","pt_BR","tr_TR","en_PH","tl_PH","th_TH","fi_FI","ko_KR","id_ID","da_DK","en_GB","en_BS","en_IN","ms_MY","en_NZ","zh_HK","en_US","nl_NL","ja_JP","ru_RU","en_AE","en_SG","sv_SE","en_CA","fr_FR","pt_PT","vi_VN","es_ES","zh_CN","en_AU","it_IT","cs_CZ","en_MY","en_HK","de_DE","zh_TW"],"real_lang":"","language_publish_status":0,"language_once_published":false,"viewable_platform":0,"publish_info":{"publish_status":0,"publish_status_desc":"","published_time_utc":""},"currency":"VND","package_id":0,"market_price":"69620","sell_price":"69620","from_price":"69620","to_price":"1665000","spec_price":{"type":0,"desc":""},"start_time":"2026-04-20 00:00:00","sold_out":false,"package_count":0,"hot_state":"","participants_format":"1M+ Đã đặt","discount":0,"card_tags":{},"tags":null,"icon":null,"icons":null,"min_trip":0,"ysim_info":{},"is_srv_activity":false,"is_nsw_activity":false,"detail_hotel":null,"NeedHideReview":false,"DeepLink":"activity/13283-ba-na-hills-ticket-da-nang/","need_hide_review":false,"deeplink":"","deep_link":"/vi/activity/13283-ba-na-hills-ticket-da-nang/","vertical_type":0,"vertical_id":0,"custom_tags":null,"tag_ids":null},{"id":4809,"instance":1,"participate":66955,"url_seo":"","video_url":"","score