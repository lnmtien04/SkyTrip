uage_once_published":false,"viewable_platform":0,"publish_info":{"publish_status":0,"publish_status_desc":"","published_time_utc":""},"currency":"VND","package_id":0,"market_price":"74000","sell_price":"74000","from_price":"74000","to_price":"1000000","spec_price":{"type":0,"desc":""},"start_time":"2026-04-20 18:15:00","sold_out":false,"package_count":0,"hot_state":"","participants_format":"100K+ Đã đặt","discount":0,"card_tags":{},"tags":null,"icon":null,"icons":null,"min_trip":0,"ysim_info":{},"is_srv_activity":false,"is_nsw_activity":false,"detail_hotel":null,"NeedHideReview":false,"DeepLink":"activity/23321-han-river-cruise-my-xuan-cruise-da-nang/","need_hide_review":false,"deeplink":"","deep_link":"/vi/activity/23321-han-river-cruise-my-xuan-cruise-da-nang/","vertical_type":0,"vertical_id":0,"custom_tags":null,"tag_ids":null}]},{"priority":0,"display_status":0,"card_url":"https://res.klook.com/image/upload/v1760521763/destination/wncqdlsfudyzz1etgoqc.jpg","name":"Hạ Long","id":486,"dest_id":0,"de\u0073\u0063\u0072\u0069\u0070\u0074ion":"Hạ Long, thành phố biển thuộc tỉnh Quảng Ninh, nổi tiếng với Vịnh Hạ Long - di sản thiên nhiên thế giới được UNESCO công nhận. Vịnh sở hữu hơn 1.600 đảo đá vôi lớn nhỏ, làn nước xanh ngọc bích và những hang động kỳ ảo như Hang Sửng Sốt, Động Thiên Cung. Chỉ cách Hà Nội khoảng 170 km, du khách có thể trải nghiệm du thuyền sang trọng, chèo thuyền kayak, tắm biển tại Bãi Cháy hay ngắm nhìn toàn cảnh vịnh từ núi Bài Thơ. Thành phố còn có Công viên Sun World Hạ Long với nhiều trò chơi giải trí hấp dẫn dành cho cả gia đình. Ẩm thực phong phú với hải sản tươi sống cũng là một điểm nhấn khiến Hạ Long trở thành điểm đến không thể bỏ qua.","location":"20.971198,107.044807","seo_url":"halong","keywords":[{"keyword":"Khu di tích thế giới","image":""},{"keyword":"Kỳ quan thiên nhiên","image":""},{"keyword":"Điểm đến không thể bỏ qua","image":""}],"hot_activities":[{"id":55771,"instance":1,"participate":34956,"url_seo":"","video_url":"https:/