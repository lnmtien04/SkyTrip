upload/activities/zrqro7zcmxtmtdjbixbf.jpg","published_language":["en_US","id_ID","ru_RU","en_CA","fi_FI","fr_FR","zh_HK","ko_KR","pl_PL","en_AU","sv_SE","nl_NL","en_NZ","pt_PT","th_TH","en_BS","tr_TR","it_IT","en_PH","ms_MY","en_IN","tl_PH","en_HK","es_ES","zh_TW","en_SG","el_GR","de_DE","vi_VN","en_AE","ja_JP","en_GB","da_DK","en_MY","pt_BR","zh_CN"],"real_lang":"","language_publish_status":0,"language_once_published":false,"viewable_platform":0,"publish_info":{"publish_status":0,"publish_status_desc":"","published_time_utc":""},"currency":"VND","package_id":0,"market_price":"506250","sell_price":"480938","from_price":"480938","to_price":"1442100","spec_price":{"type":0,"desc":""},"start_time":"2026-04-20 00:00:00","sold_out":false,"package_count":0,"hot_state":"","participants_format":"6K+ Đã đặt","discount":0,"card_tags":{},"tags":null,"icon":null,"icons":null,"min_trip":0,"ysim_info":{},"is_srv_activity":false,"is_nsw_activity":false,"detail_hotel":null,"NeedHideReview":false,"DeepLink":"activity/158197-experience-saigon-river-sunset-on-luxury-icon-saigon-cruise/","need_hide_review":false,"deeplink":"","deep_link":"/vi/activity/158197-experience-saigon-river-sunset-on-luxury-icon-saigon-cruise/","vertical_type":0,"vertical_id":0,"custom_tags":null,"tag_ids":null}]},{"priority":0,"display_status":0,"card_url":"https://res.klook.com/image/upload/cities/ysnkhkzabobjbg72x3sz.jpg","name":"Hà Nội","id":34,"dest_id":0,"de\u0073\u0063\u0072\u0069\u0070\u0074ion":"Hà Nội, thủ đô của Việt Nam, một thành phố của truyền thống và lịch sử. Sở hữu tinh hoa văn hóa dân tộc, thủ đô Hà Nội hội tụ những nét đẹp truyền thống dân gian đặc trưng của Việt Nam với hơn 1000 năm tuổi và là một trong những điểm du lịch thu hút đông đảo du khách từ khắp mọi nơi. Thủ đô Hà Nội nằm ở vị trí đắc địa, dễ dàng di chuyển đến các điểm du lịch khác như Sapa, Vịnh Hạ Long, Ninh Bình và Mộc Châu.\n\nHà Nội thuộc kiểu khí hậu nhiệt đới gió mùa ẩm và có bốn mùa rõ rệt. Mỗi mùa đều có những đặc trưng riêng và mang lại những trải nghiệm khác nhau. Từ tháng 8 đến tháng 10 hoặc vào mùa xuân là khoảng thời gian thích hợp nhất để đi du lịch Hà Nội. Ngoài ra, thủ đô Hà Nội còn được biết đến với những mùa hoa rực rỡ trong 12 tháng của năm, với mỗi tháng là dịp một loài hoa đua nhau khoe sắc.\n\nĐược mệnh danh là thành phố “nghìn năm văn hiến”, Hà Nội là nơi có nhiều di tích lịch sử nổi tiếng. Bạn có thể ghé thăm Lăng Chủ Tịch Hồ Chí Minh để chiêm ngưỡng công trình kiến ​​trúc độc đáo và tưởng nhớ về vị lãnh tụ vĩ đại của dân tộc Việt Nam. Ngoài ra, Văn Miếu Quốc Tử Giám là nơi hoàn hảo để tìm hiểu thêm về lịch sử về hình thành truyền thống hiếu học của người Việt. Một địa điểm khác không thể bỏ qua đối với bất kỳ ai khi đến thăm thủ đô là Nhà Thờ Lớn Hà Nội, nơi giao thoa giữa hai nền văn hóa phương Đông và phương Tây với nét kiến ​​trúc đặc trưng. Đây cũng là “toạ độ sống ảo” mới mẻ được đông đảo #teamKlook ưa chuộng. Sát cạnh Nhà Thờ Lớn Hà Nội còn có nhiều quán café đẹp cũng như tiệm “trà chanh nhà thờ” nổi tiếng. Bạn không nên bỏ lỡ đâu đấy.\n\nVào những ngày tiết trời mát mẻ, hãy tham quan Hồ Hoàn Kiếm, một danh lam thắng cảnh nổi tiếng với ngôi chùa độc đáo giữa hồ. Thưởng thức ẩm thực Việt Nam tại Phố Cổ Hà Nội và khám phá kiến ​​trúc thuộc địa Pháp thế kỷ 19. Đừng bỏ lỡ Vịnh Hạ Long, một khu vực ven biển nổi tiếng với các di tích tự nhiên nằm cách thành phố không xa. Tham quan Động Thiên Cung, khu vực lớn thứ hai, và ghé thăm làng chài Ba Hang để có cái nhìn sâu sắc hơn về cuộc sống địa phương.\n\nVới Klook Vietnam, du lịch Hà Nội và các điểm đến lân cận chưa bao giờ thú vị, tiện lợi và tiết kiệm đến vậy. Hàng loạt hoạt động vui chơi, giải trí, du ngoạn thiên nhiên, văn hoá, ẩm thực, nghỉ dưỡng, dịch vụ di chuyển, tour trong ngày… đang chờ bạn khám phá, với quy trình đặt hàng “một chạm” siêu tiện lợi. #teamKlook cũng đừng bỏ qua các chương trình khuyến mãi và mãi ưu đãi độc quyền hấp dẫn nhé.\n","location":"21.027764,105.834160","seo_url":"hanoi","keywords":[{"keyword":"Khám phá nông thôn","image":""},{"keyword":"Lịch sử và Văn hóa","image":""},{"keyword":"Kỳ quan thiên nhiên","image":""},{"keyword":"Điểm đến không thể bỏ qua","image":""}],"hot_activities":[{"id":133909,"instance":1,"participate":296266,"url_seo":"","video_url":"https://res.klook.com/video/upload/fl_lossy.progressive,q_85,f_auto/c_fill,,/c_scale,h_540,vc_auto/c_scale,g_north_west,h_20,l_whitelogo_hz5dq1,o_30,x_70,y_480/v1756729118/activities/tlbkxot3k2qhzgjvj0lq.mp4","score":4.4,"published":true,"review_total":7087,"title":"Xe giường nằm Hà Nội - Sapa của HK Buslines","date_de\u0073\u0063\u0072\u0069\u0070\u0074ion":"","template_id":5,"sub_category":0,"leaf_category":582,"country_id":13,"country_code":"","city_id":34,"city_name":"","latlng":"21.0328834,105.8543237","latlng_wgs84":"","first_publish_time":"2024-10-17T17:41:33.000Z","display_package_card":0,"image_url":"","country_name":"","activity_type":"","image_url_host":"https://res.klook.com/image/upload/activities/wpgi42x75p8zqgzjvnq4.jpg","published_language":["en_BS","fi_FI","en_GB","en_PH","id_ID","en_IN","en_NZ","en_MY","en_SG","it_IT","en_HK","en_AU","vi_VN","th_TH","el_GR","zh_HK","zh_CN","zh_TW","es_ES","cs_CZ","de_DE","en_CA","ms_MY","ko_KR","ru_RU","en_US","en_AE","ja_JP","fr_FR"],"real_lang":"","language_publish_status":0,"language_once_published":false,"viewable_platform":0,"publish_info":{"publish_status":0,"publish_status_desc":"","published_time_utc":""},"currency":"VND","package_id":0,"market_price":"420000","sell_price":"389500","from_price":"389500","to_price":"560500","spec_price":{"type":0,"desc":""},"start_time":"2026-04-21 00:15:00","sold_out":false,"package_count":0,"hot_state":"","participants_format":"200K+ Đã đặt","discount":0,"card_tags":{},"tags":null,"icon":null,"icons":null,"min_trip":0,"ysim_info":{},"is_srv_activity":false,"is_nsw_activity":false,"detail_hotel":null,"NeedHideReview":false,"DeepLink":"activity/133909-hanoi-sapa-sleeper-bus-by-hk-buslines/","need_hide_revi