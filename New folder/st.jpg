":"activity/190897-hercules-grand-luxury-day-cruise-ha-long-bay-sung-sot-ti-top/","need_hide_review":false,"deeplink":"","deep_link":"/vi/activity/190897-hercules-grand-luxury-day-cruise-ha-long-bay-sung-sot-ti-top/","vertical_type":0,"vertical_id":0,"custom_tags":null,"tag_ids":null},{"id":7448,"instance":1,"participate":64397,"url_seo":"","video_url":"","score":4.5,"published":true,"review_total":4644,"title":"[Tuyến 1] Tour Tham Quan Vịnh Hạ Long Nhóm Nhỏ với Tàu Dragon Cruise","date_de\u0073\u0063\u0072\u0069\u0070\u0074ion":"","template_id":2,"sub_category":0,"leaf_category":156,"country_id":13,"country_code":"","city_id":486,"city_name":"","latlng":"20.9224804,106.9907306","latlng_wgs84":"","first_publish_time":"2017-11-15T17:41:39.000Z","display_package_card":0,"image_url":"","country_name":"","activity_type":"","image_url_host":"https://res.klook.com/image/upload/activities/qmgtdjekctlyucr8itqw.jpg","published_language":["nb_NO","zh_CN","cs_CZ","ta_IN","fr_FR","pt_PT","en_BS","fi_FI","en_SG","si_LK","zh_HK","ko_KR","pt_BR","en_NZ","en_PH","ru_RU","bn_BD","sv_SE","en_US","id_ID","es_ES","en_GB","tr_TR","nl_NL","en_AU","en_IN","ja_JP","hu_HU","tl_PH","vi_VN","hi_IN","en_CA","bg_BG","en_HK","zh_TW","el_GR","da_DK","ca_ES","pl_PL","de_DE","th_TH","it_IT","en_MY","ms_MY","en_AE","ro_RO","sk_SK"],"real_lang":"","language_publish_status":0,"language_once_published":false,"viewable_platform":0,"publish_info":{"publish_status":0,"publish_status_desc":"","published_time_utc":""},"currency":"VND","package_id":0,"market_price":"906569","sell_price":"815912","from_price":"815912","to_price":"1109480","spec_price":{"type":0,"desc":""},"start_time":"2026-04-20 00:00:00","sold_out":false,"package_count":0,"hot_state":"","participants_format":"60K+ Đã đặt","discount":0,"card_tags":{"klook_choice":"Klook chọn lọc"},"tags":[{"key":"klook_choice","background_color_left":"#FF5722","background_color_right":"#FF5722","text_color":"#FFFFFF","text":"Klook chọn lọc"}],"icon":null,"ic