e.com/@Klook_Travel/"},{"icon":"Instagram","icon_alt":"Instagram","icon_src":"https://res.klook.com/image/upload/v1744785757/ued/Other/social%20media/Instagram.png","link":"https://www.instagram.com/klookmy/"},{"icon":"X","icon_alt":"X","icon_src":"https://res.klook.com/image/upload/v1744785757/ued/Other/social%20media/X.png","link":"https://x.com/klooktravel"},{"icon":"TikTok","icon_alt":"TikTok","icon_src":"https://res.klook.com/image/upload/v1744785757/ued/Other/social%20media/TikTok.png","link":"https://www.tiktok.com/@klook.my"},{"icon":"Telegram","icon_alt":"Telegram","icon_src":"https://res.klook.com/image/upload/v1744785757/ued/Other/social%20media/Telegram.png","link":"https://t.me/klookmy"},{"icon":"XiaoHongShu","icon_alt":"Xiao Hong Shu","icon_src":"https://res.klook.com/image/upload/v1745389990/ued/Other/social%20media/xiaoshongshu.png","link":"https://www.xiaohongshu.com/user/profile/62288db30000000010009ae7"}],"zh-HK":[{"icon":"Meta","icon_alt":"Meta","icon_src":"https://res.klook.com/image/upload/v1744785757/ued/Other/social%20media/Meta.png","link":"https://www.facebook.com/klookhk/"},{"icon":"Youtube","icon_alt":"Youtube","icon_src":"https://res.klook.com/image/upload/v1747821955/ued/Other/social%20media/Youtube1.png","link":"https://www.youtube.com/@klookhk8644/"},{"icon":"Instagram","icon_alt":"Instagram","icon_src":"https://res.klook.com/image/upload/v1744785757/ued/Other/social%20media/Instagram.png","link":"https://www.instagram.com/klookhk/"},{"icon":"Threads","icon_alt":"Threads","icon_src":"https://res.klook.com/image/upload/v1744785757/ued/Other/social%20media/Threads.png","link":"https://www.threads.net/@klookhk"}],"zh-TW":[{"icon":"Meta","icon_alt":"Meta","icon_src":"https://res.klook.com/image/upload/v1744785757/ued/Other/social%20media/Meta.png","link":"https://www.facebook.com/klooktw/"},{"icon":"Instagram","icon_alt":"Instagram","icon_src":"https://res.klook.com/image/upload/v1744785757/ued/Other/social%20media/Instagram.png","link":"https://www.instagram.com/klooktw/"},{"icon":"Threads","icon_alt":"Threads","icon_src":"https://res.klook.com/image/upload/v1744785757/ued/Other/social%20media/Threads.png","link":"https://www.threads.net/@klooktw"}]}};
        var KLK_AID_CONF = null || {};
        var KLK_QS_AID_CONF = null || {};
        var KLK_PAGE_AD = undefined;
        var KLK_PREVIEW_INCREMENT_LOCALES = null;
        var KLK_INCREMENT_LOCALES = null;
        var KLK_CLIENT_LOGQUERY_HOST = 'https://log.klook.com';
        var KLK_GA4_ID = 'G-V8S4KC8ZXR';
    </script>
    <script>
    </script>
    <script crossorigin src="https://cdn.klook.com/s/dist_web/assert/desktop/js/manifest-adc70af158.bundle.js"></script>
    <script crossorigin src="https://cdn.klook.com/s/dist_web/assert/comm/locales/lang-d57b0f9439.locale-vi.js" ></script>
    <script crossorigin src="https://cdn.klook.com/s/dist_web/assert/desktop/js/vendor-936a0c604d.bundle.js"></script>
    <script data-src="https://cdn.klook.com/s/dist_web/assert/desktop/js/kakao_min-1aab8cae28.js"  id="abtest5492_script"></script>
    <script crossorigin data-src="https://cdn.klook.com/s/dist_web/assert/desktop/js/signup_v2-ca6acbb6a3.bundle.js" id="abtest5492_script_signup"></script>
    <script crossorigin data-src="https://cdn.klook.com/s/dist_web/assert/desktop/js/login_v2-562c73b6f0.bundle.js" id="abtest5492_script_login"></script>

<script type="text/x-template" id="tpl-map-card">
    <div class="js-map-card js-map-card-id-{{ id }} act_block act_block_ms" data-track-event="Country Page|Map View Section Destination Clicked|{{id}}">
    <a 
        href="/{{@root._lang_path}}city/{{id}}-{{seo_url}}/" 
        target="_blank"
        class="j_activity_item_link" data-id="{{id}}" data-url-seo="{{url_seo}}">

        <div class="m_bg city-img" style="background-image: url({{format_pic_url (set_new_image_size card_url 'image/upload/' 216 216)}};"></div>
        <div class="city-detail">
            <div class="t_nowrap">{{name}}</div>
            <p>{{description}}</p>
        </div>
    </a>
</div>
</script>

<script type='text/x-template' id='tpl_activities_page'>
    <div>
        {{#data}}
        {{#unless hasActivities}}
        <div class="clear_all_filter">
            <div class="img"></div>
            <div class="clear_text">
                <h3>{{t 'search_sorry_no_results_found'}}</h3>
                <p>{{{t 'search_clear_all'}}}</p>
            </div>
        </div>
        {{/unless}}
        {{#if hasActivities}}
        <!-- 搜索结果卡片 -->
        <div class="act_list">

        </div>
        {{/if}}
        {{/data}}
    </div>
</script>

<script type="text/x-template" class="tpl_pagination">
    {{#pre}}
    <a href="{{url}}" class="pre">&lt;</a>
{{/pre}}
{{#first_page}}
    <a class="p_num" href="{{url}}" rel="pre">{{page}}</a>
{{/first_page}}
{{#first_etc}}
<span>...</span>
{{/first_etc}}
{{#middle_page}}
    <a class="p_num {{#current}}current{{/current}}" href="{{url}}" {{#unless current}}rel="{{isPre}}"{{/unless}}>{{page}}</a>
{{/middle_page}}
{{#last_etc}}
<span>...</span>
{{/last_etc}}
{{#last_page}}
    <a class="p_num" href="{{url}}" rel="next">{{page}}</a>
{{/last_page}}
{{#next}}
    <a href="{{url}}" class="next" >&gt;</a>
{{/next}}

</script>

<script type="text/x-template" class="tpl_new_card">
    <div class="m_justify_list m_radius_box act_card act_card_{{card_size}} {{#unless (eq card_size 'profile')}}a_sd_move{{/unless}} j_activity_item js-item {{#if sold_out}}sold_out {{/if}} {{#if (and what_we_love showSeoDesc)}}{{#unless (formatFirstImg what_we_love)}}act_card_sm_describe {{/unless}}{{/if}}"
     {{#if module}}data-spm-module="{{module}}?oid={{#if (and vertical_type vertical_id) }}{{vertical_type}}_{{vertical_id}}{{else}}activity_{{id}}{{/if}}{{#if moduleExtra}}{{moduleExtra}}{{/if}}"{{/if}}>
    <!-- {{#if (isHotelVoucher template_id)}}hotel-vouchers{{else}}activity{{/if}} -->
    <div data-galileo-click="__default" data-spm-item="__default?typ=entry"
    class="j_activity_item_link j_activity_item_click_action"

    {{#if card_tags}}
    data-card-tags='{{htmlJson card_tags}}'

    {{#if card_tags.editor_choice}}
    data-prefer-tag="1"
    {{else if card_tags.bestseller}}
    data-prefer-tag="2"
    {{else if card_tags.new_activity}}
    data-prefer-tag="3"
    {{/if}}
    {{/if}}
    data-prefer-tag="0"

    {{#if is_klook_referral}}
    data-stat='{{json stat}}'
    {{/if}}

    {{#if deep_link}}
    data-href="{{deep_link}}"
    {{else if is_klook_referral}}
    data-href="/{{@root._lang_path}}activity/{{id}}-{{url_seo}}/#krt={{stat.klook_referral_type}}&krid={{stat.klook_referral_id}}"
    {{else}}
    data-href="/{{@root._lang_path}}activity/{{id}}-{{url_seo}}/"
    {{/if}}

    {{#if (eq _type 'popular_activity') }}
    data-track-event="Destination Page V2|Popular Activity Section Activity Clicked|{{ id }}"
    {{/if}}

    {{#if (eq _type 'city_theme') }}
    data-track-event="Destination Page V2|Destination Theme Activity Clicked|{{ _theme_id }},{{ id }}"
    {{/if}}

    {{#if (eq _type 'city_map_card') }}
    data-track-event="Destination Page V2|Map View Section Activity Clicked|{{ id }}"
    {{/if}}

    {{#if (eq _type 'recommend') }}
    data-track-event="{{ track_event }}"
    {{/if}}
    {{#if _theme_id }}
    data-theme-id={{_theme_id}}
    {{/if}}
    {{#if target_Blank }}
    data-target-blank="_blank"
    {{/if}}
    {{#if object_type}}
    data-object-type="{{object_type}}"
    {{else}}
    data-object-type="act"
    {{/if}}
    data-sold-out="{{sold_out}}"
    data-price="{{sell_price}}"
    data-city-id="{{city_id}}"
    data-country-id="{{country_id}}"
    data-template-id="{{template_id}}"
    data-id="{{id}}"
    data-url-seo="{{url_seo}}" {{#if _gatag}} data-gatag="{{_gatag}}" {{/if}}>
        <div class="m_bg lazy lazy-hot" style="display: block;"
            {{#if image_url}}
            data-original="{{format_pic_url image_url 'activity_card'}}"
            {{else}}
            data-original="{{format_pic_url (set_new_image_size image_url_host 'image/upload/' 800 488)}}"
            {{/if}}
             data-noHidden="true"
        >
            <div class="g_l_box top m_radius_box">
                {{#unless hide_location}}
                    {{#if city_name}}
                        <i class="klook-icon-act-location t_white t16"></i>
                        <span class="t_white">{{city_name}}</span>
                    {{/if}}
                {{/unless}}

                {{#evl "this.video || this.video_url"}}
                <i data-id="{{id}}" class="klook-icon-video2 t_white t24 g_right"></i>
                {{/evl}}
            </div>
            <div class="g_l_box bottom">
                {{! A/B WS-7754 }}
                    {{#if (abtest7754_var2 'tab' id title @root._lang)}}
                    <p class="discount_tip t12 t_white abtest7754_var2"  style="display: none;">
                        {{abtest7754_var2 'tab' id title @root._lang}}
                    </p>
                    {{/if}}
                {{! A/B WS-7754 }}
                {{#unless hide_tags}}
                {{#unless sold_out}}

                {{#tags}}
                  <p class="tag_tip t12" style="color:{{text_color}};background-image: linear-gradient(to right, {{background_color_left}} , {{background_color_right}});">
                      {{text}}
                  </p>
                {{/tags}}

                {{#if show_collect}}
                <i class="klook-icon-collect-v2 t_white t24 g_right"></i>
                {{/if}}
                {{/unless}}
                {{/unless}}
            </div>
        </div>
        <ul class="">
            <li class="g_rel">
                {{! A/B WS-7754 }}
                    {{#if (abtest7754_var2 'title' id title @root._lang)}}
                    <p class="title abtest7754_var2" style="display: none;">
                        {{abtest7754_var2 'title' id title @root._lang}}
                    </p>
                    {{/if}}
                {{! A/B WS-7754 }}

                <a class="title"
                {{#if deep_link}}
                href="{{deep_link}}"
                {{else if is_klook_referral}}
                href="/{{@root._lang_path}}activity/{{id}}-{{url_seo}}/#krt={{stat.klook_referral_type}}&krid={{stat.klook_referral_id}}"
                {{else}}
                href="/{{@root._lang_path}}activity/{{id}}-{{url_seo}}/"
                {{/if}} {{#if target_Blank}} target='_blank' {{/if}}>
                    {{title}}
                </a>

                {{#unless hide_tags}}
                {{#unless sold_out}}
                    {{#if card_tags.new_activity}}
                    <i class="flag-new t_main" >
                        <span class="pop_up f_hidden">{{card_tags.new_activity}}</span>
                    </i>
                    {{/if}}

                    {{#unless hide_bestseller}}
                    {{#if card_tags.bestseller}}
                    <i class="flag-hot t_main" >
                        <span class="pop_up f_hidden">{{card_tags.bestseller}}</span>
                    </i>
                    {{/if}}
                    {{/unless}}

                {{#unless hide_editor_choice}}
                {{#if card_tags.editor_choice}}
                    <i class="prefer t_main j_perfer-tag">
                        <svg class="klook-symbol preferred_tag_icon_bg">
                            <use xlink:href="#icon-klook-preferred-badge"></use>
                        </svg>
                    </i>
                    {{/if}}
                {{/unless}}
                {{/unless}}
                {{/unless}}
            </li>
            {{#unless (eq card_size 'profile')}}
            <li class="t12 t_gray star_box">
                {{#if (not need_hide_review)}}
                <!--                修改评分展示逻辑，评分小于4且数量小于10不展示-->
                {{#evl 'this.score && this.review_total >0' }}
                <span class="">
                    <span class="m_star_v2">
                        <i class="klook-icon-star"></i>
                        <span class="t14 star_score">{{parse_float_1 score}}</span>
                    </span>
                    <span class="u_t_gray_9">({{t 'global.star.reviews' (formatReviewThousands review_total)}})</span>
                </span> {{#if participants_format}}|{{/if}}
                {{/evl}}
                {{/if}}
                {{#if participants_format}}
                <span class="u_t_gray_9">{{participants_format}}</span>
                {{/if}}
            </li>
            {{/unless}}
            {{#if (and what_we_love showSeoDesc) }}
                {{#unless (formatFirstImg what_we_love)}}
                  {{#unless (isHotelVoucher template_id)}}
                    <li class="describe-box">
                        <p class="describe {{#if (eq @root._res_en_lang 'en')}}en{{else}}tw{{/if}}">{{markdown_args_img_p (formatFirstParagraphEn what_we_love)}}</p>
                    </li>
                  {{/unless}}
                {{/unless}}
            {{/if}}
            <li class="price">
                <p class="del_price u_t_gray_9">
                    {{#unless (eq sell_price 0)}}
                    {{#if (gt market_price sell_price)}}
                    <del><span>{{@root._currency_symbo}}</span> {{formatPriceThousands market_price}}</del>
                    {{/if}}
                    {{/unless}}
                    &nbsp;
                </p>
                <p>
                    <span class="latest_price">
                        {{#if (eq object_type 'event')}}
                            {{#if (gt to_price from_price)}}
                                {{{t 'activity_detail_from_price' '14' (handleActivityCardPrice @root._currency_symbo sell_price from_price to_price)}}}
                            {{else if (eq sell_price '')}}
                            {{else if (eq sell_price 0)}}
                                 <b>{{spec_price.desc}}</b>
                            {{else}}
                                <b>{{@root._currency_symbo}} {{formatPriceThousands sell_price}}</b>
                            {{/if}}
                        {{else}}
                            {{#if (eq sell_price '')}}
                            {{else if (eq sell_price 0)}}
                            <b>
                                {{spec_price.desc}}
                            </b>
                            {{else if (gt to_price from_price)}}
                                {{{t 'activity_detail_from_price' '14' (handleActivityCardPrice @root._currency_symbo sell_price from_price to_price)}}}
                            {{else}}
                            <b>{{@root._currency_symbo}} {{formatPriceThousands sell_price}}</b>
                            {{/if}}
                        {{/if}}
                    </span>
                    {{#if (gt sell_price -1)}}
                    {{#evl "this.is_instance == 1 || this.instance == 1 || this.instant == 1 "}}
                    <span class="klook-fast_box">
                        <i class="t14 klook-icon-fast t_main "></i>
                    </span>
                    {{/evl}}
                    {{/if}}

                    {{#unless sold_out}}
                    {{#unless (eq vertical_type '101')}}
                        <!-- 目前有些接口对于hotel还没返回业务字段hotel_end_time  -->
                        {{#if (isHotelVoucher template_id)  }}
                            {{#if (and hotel_begin_time hotel_end_time )}}
                                <span class="g_right hotel_card_time">
                                    <span>
                                        Hạn sử dụng Voucher:
                                    </span>
                                    <span>
                                        {{format_standard_date_new hotel_begin_time @root._lang 2}} - {{format_standard_date_new hotel_end_time @root._lang 2}}
                                    </span>
                                </span>
                            {{/if}}
                        {{else}}
                            <span class="g_right j_card_date" style="max-width: 100%;overflow: hidden;text-overflow: ellipsis;white-space: nowrap;" data-serverdate="{{start_time}}"></span>
                        {{/if}}
                    {{/unless}}
                    {{/unless}}
                </p>
            </li>
        </ul>
    </div>
    {{#if sold_out}}
    <span class="soldout t_black t16 f_hidden">Bán hết</span>
    {{/if}}
    {{#if wishlist}}
    <div class="t_mid collectBtn {{#if reopen}}wishlist_left_pad{{else}}wishlist_center{{/if}}"
        data-galileo-click="__default" data-spm-item="AddToFavorite?ext={ClickType: 'Cut'}">
        <i class="klook-icon-collect t_main"></i>
        <span>Bỏ khỏi yêu thích</span>
        {{#if reopen}}
        <div class="reopen_btn">
            ...
            <div class="reopen_poptip-wrapper">
                <div class="poptip-popper-inner">
                    <div class="poptip-popper-arrow"></div>
                    <div class="poptip-popper-content">
                        <div class='poptip-popper-txt'>{{reopen.description}}</div>
                        <div class="switch-container {{#if reopen.button}}switch-container-checked{{else}}colse-checked{{/if}}">
                            <div class="switch-track"></div>
                            <div class="switch-thumb"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{/if}}
    </div>
    {{/if}}
</div>

</script>

<script>
    var klkCountryPageInfo = {"hot_cities":[{"priority":0,"display_status":0,"card_url":"https://res.klook.com/image/upload/v1755071862/destination/lnzgvjcuxplxfmfeazah.jpg","name":"Thành phố Hồ Chí Minh","id":33,"dest_id":0,"de\u0073\u0063\u0072\u0069\u0070\u0074ion":"Thành phố Hồ Chí Minh, hay còn gọi là Sài Gòn, mang trong mình một nền văn hóa đa dạng và đặc sắc. Với hai mùa nắng mưa rõ rệt và vẻ đẹp tân cổ hài hoà, thành phố Hồ Chí Minh chắc chắn là một chặng dừng chân khó quên cho tất cả du khách.\n\nBạn có thể dành nửa ngày để tham quan Địa Đạo Củ Chi hay tìm hiểu về những khu di tích giàu ý nghĩa lịch sử trong thời kỳ Chiến Tranh Việt Nam. Hãy trải nghiệm cuộc sống gần gũi như một người dân địa phương trong chuyến tham quan Sài Gòn bằng xe máy và ghé thăm các địa danh nổi tiếng như Bưu Điện Thành Phố và Nhà Hát Thành Phố.\n\nNằm ở vị trí thuận lợi, thành phố Hồ Chí Minh là đầu mối di chuyển đến nhiều địa điểm tham quan nổi tiếng như miền Tây sông nước và vùng ven biển quyến rũ. Khám phá một khía cạnh khác của miền Nam đất nước khi bạn xuôi dòng về Đồng Bằng Sông Cửu Long, ghé thăm làng chài nổi tiếng với những ngôi nhà mái lá và cánh đồng lúa bát ngát. Đừng quên thử thưởng thức các món đặc sản theo mùa như kẹo dừa thơm ngon làm tại chỗ.\n\nVới dịch vụ trung chuyển tiện lợi như thuê xe hơi riêng, xe buýt hop on hop off, du khách dễ dàng khám phá mọi ngóc ngách của thành phố Hồ Chí Minh và nhiều hơn thế nữa. Sở hữu nền ẩm thực phong phú, thành phố Hồ Chí Minh mang đến danh sách món ăn ngon nhiều không kể xiết - từ ẩm thực đường phố tại khu chợ truyền thống đến tiệc buffet sang trọng. Khi màn đêm buông xuống, nhịp sống tại Sài Gòn trở nên sôi động hơn với đa dạng hoạt động hấp dẫn. Còn gì tuyệt vời hơn khi vi vu vào buổi tối tại các khu vực nổi tiếng như Phố Đi Bộ Nguyễn Huệ, Tháp Bitexco để hòa mình vào dòng người tấp nập. Khu trung tâm thành phố Hồ Chí Minh không thiếu những khách sạn giá rẻ và điểm lưu trú an toàn cho chuyến đi của bạn.\n\nDu lịch thành phố Hồ Chí Minh, bạn có thể tận hưởng giây phút thư giãn tại nhiều hệ thống spa cao cấp ở Sài Gòn bằng cách đặt dịch vụ tiện lợi trong “một chạm” trên Klook Vietnam. Chỉ cần vài phút lựa chọn, Klook sẽ mang đến cho bạn nhiều dịch vụ hấp dẫn và mới lạ để khám phá trọn vẹn một Sài Gòn đầy niềm vui. Du khách sẽ được trải nghiệm các hoạt động du lịch thú vị tại thành phố Hồ Chí Minh trên Klook với nhiều ưu đãi hấp dẫn mỗi ngày và quy trình đặt hàng vô cùng tiện lợi.\n\nThành phố Hồ Chí Minh hứa hẹn là một điểm tham quan du lịch đáng nhớ cho tất cả mọi người. Đặt ngay các sản phẩm trên Klook để tận hưởng những ưu đãi giới hạn và cùng gia đình, bạn bè tận hưởng những giây phút đáng nhớ tại Sài Gòn nhé.\n","location":"10.823099,106.629664","seo_url":"ho-chi-minh-city","keywords":[{"keyword":"Khám phá nông thôn","image":""},{"keyword":"Lịch sử và Văn hóa","image":""},{"keyword":"Kiến trúc ấn tượng","image":""}],"hot_activities":[{"id":123902,"instance":1,"participate":382397,"url_seo":"","video_url":"","score":4.6,"published":true,"review_total":9283,"title":"5G eSIM Việt Nam | Viettel","date_de\u0073\u0063\u0072\u0069\u0070\u0074ion":"","template_id":8,"sub_category":0,"leaf_category":639,"country_id":13,"country_code":"","city_id":34,"city_name":"","latlng":"0,0","latlng_wgs84":"","first_publish_time":"2024-07-16T14:43:40.000Z","display_package_card":0,"image_url":"","country_name":"","activity_type":"","image_url_host":"https://res.klook.com/image/upload/activities/izny7ql5ylxhdpitgvyy.jpg","published_language":["en_AU","en_PH","tl_PH","ru_RU","en_HK","en_NZ","en_MY","sv_SE","pl_PL","ja_JP","th_TH","fi_FI","en_CA","fr_FR","zh_TW","id_ID","tr_TR","ms_MY","vi_VN","en_SG","ko_KR","en_GB","pt_BR","nl_NL","en_BS","de_DE","zh_HK","en_IN","pt_PT","da_DK","it_IT","zh_CN","en_US","cs_CZ","es_ES","en_AE"],"real_lang":"","language_publish_status":0,"language_once_published":false,"viewable_platform":0,"publish_info":{"publish_status":0,"publish_status_desc":"","published_time_utc":""},"